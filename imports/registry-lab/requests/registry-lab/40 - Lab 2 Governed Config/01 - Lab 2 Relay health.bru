meta {
  name: 01 - Lab 2 Relay health
  type: http
  seq: 1
}

get {
  url: {{lab2_civil_relay_url}}/healthz
  body: none
  auth: none
}

headers {
  x-api-key: {{CIVIL_METADATA_CLIENT_RAW}}
}

script:post-response {
  const body = res.getBody();

  test("status is 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("relay reports healthy liveness", function () {
    expect(body).to.have.property("status", "ok");
  });
}
