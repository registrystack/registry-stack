# syntax=docker/dockerfile:1.7

FROM rust:1-bookworm AS builder

WORKDIR /workspace/registry-notary
COPY --from=registry_platform_src Cargo.toml README.md LICENSE /workspace/registry-platform/
COPY --from=registry_platform_src crates /workspace/registry-platform/crates
COPY --from=crosswalk_src Cargo.toml Cargo.lock README.md /workspace/crosswalk/
COPY --from=crosswalk_src crates /workspace/crosswalk/crates
# Deprecated compatibility path for vendored checkouts whose Cargo.toml still
# declares the ../cel-mapping path dependency; remove once all vendor pins
# reference ../crosswalk.
RUN ln -sfn /workspace/crosswalk /workspace/cel-mapping
COPY --from=notary_src . .

RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/workspace/target \
    CARGO_TARGET_DIR=/workspace/target cargo build --release --locked -p registry-notary-openfn-sidecar \
    && cp /workspace/target/release/registry-notary-openfn-sidecar /usr/local/bin/registry-notary-openfn-sidecar

FROM node:22-bookworm-slim AS runtime

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/openfn
COPY --from=notary_src crates/registry-notary-openfn-sidecar/workers/package.json ./package.json
COPY --from=notary_src crates/registry-notary-openfn-sidecar/workers/package-lock.json ./package-lock.json
RUN npm ci --omit=dev --ignore-scripts --no-audit --no-fund

COPY --from=builder /usr/local/bin/registry-notary-openfn-sidecar /usr/local/bin/registry-notary-openfn-sidecar
COPY --from=notary_src crates/registry-notary-openfn-sidecar/workers/openfn_worker.mjs ./openfn_worker.mjs
COPY --from=notary_src crates/registry-notary-openfn-sidecar/examples/jobs/http-person-lookup.js ./jobs/http-person-lookup.js
COPY --from=notary_src crates/registry-notary-openfn-sidecar/examples/mock-registry-server.mjs ./mock-registry-server.mjs
COPY config/openfn/jobs/dhis2-*.js ./jobs/

USER node
EXPOSE 8080

ENTRYPOINT ["registry-notary-openfn-sidecar"]
