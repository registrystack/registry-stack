{
  "mapping_id": "nagdi-agri-publicschema-projection-v1",
  "description": "Demo PublicSchema projection from Registry Relay agriculture entities. The source workbooks remain operational XLSX files; this mapping describes generated semantic exports.",
  "mapping_files": {
    "Persons": "config/publicschema/agri-publicschema-projection/person.yaml",
    "Identifiers": "config/publicschema/agri-publicschema-projection/identifier.yaml",
    "Farms": "config/publicschema/agri-publicschema-projection/farm.yaml",
    "GroupMemberships": "config/publicschema/agri-publicschema-projection/group-membership.yaml",
    "Locations": "config/publicschema/agri-publicschema-projection/location.yaml"
  },
  "targets": {
    "Person": {
      "concept_uri": "https://publicschema.org/Person",
      "source_entity": "farmer",
      "id_template": "person:{id}"
    },
    "Identifier": {
      "concept_uri": "https://publicschema.org/Identifier",
      "source_entity": "farmer_identifier",
      "id_template": "identifier:{id}"
    },
    "Farm": {
      "concept_uri": "https://publicschema.org/Farm",
      "source_entity": "holding",
      "id_template": "farm:{id}"
    },
    "GroupMembership": {
      "concept_uri": "https://publicschema.org/GroupMembership",
      "source_entities": ["farmer_group_membership", "holding"],
      "id_template": "membership:{id}"
    },
    "Location": {
      "concept_uri": "https://publicschema.org/Location",
      "source_entities": ["farmer", "holding"],
      "id_template": "location:{district_code}"
    }
  }
}
