{
  "schema": "registry.notary.openfn_sidecar.runtime.v1",
  "limits": {
    "max_workers": 4,
    "worker_timeout_ms": 15000,
    "max_output_bytes": 1048576,
    "max_request_bytes": 16384,
    "max_query_parameter_bytes": 1024,
    "liveness_window_ms": 30000,
    "retry_after_seconds": 1,
    "max_batch_items": 100,
    "max_worker_memory_mb": 12288
  },
  "openfn": {
    "cli_build_tool": "1.2.5",
    "runtime": "1.9.3"
  },
  "jobs_root": "/tmp/registry-lab-openfn-jobs",
  "worker": {
    "command": "node",
    "args": [
      "--experimental-vm-modules",
      "/opt/openfn/openfn_worker.mjs"
    ],
    "version_args": [
      "--experimental-vm-modules",
      "/opt/openfn/openfn_worker.mjs",
      "--version",
      "--require-adaptor",
      "@openfn/language-http@7.3.1",
      "--require-adaptor",
      "@openfn/language-common@3.2.3"
    ]
  },
  "sources": {
    "dhis2_health": {
      "dataset": "dhis2_tracker",
      "entity": "person",
      "engine": "openfn",
      "workflow": {
        "start": "lookup",
        "batch_mode": "per_item",
        "steps": [
          {
            "id": "lookup",
            "expression": "dhis2-health-lookup.js",
            "expression_sha256": "sha256:245161afe436d38318fbcf65a3685ac86d16ad96debe818410046be01f5000da",
            "adaptors": [
              "@openfn/language-http@7.3.1"
            ]
          }
        ]
      },
      "credential_env": "OPENFN_DHIS2_DEMO_CREDENTIAL_JSON",
      "credential_public_fields": [],
      "allowed_base_urls": [
        "https://play.im.dhis2.org/stable-2-43-0-1"
      ],
      "allow_insecure_localhost": false,
      "allow_insecure_private_network": false,
      "smoke_lookup": {
        "field": "tracked_entity",
        "value": "PQfMcpmXeFE",
        "query_values": {},
        "fields": [
          "tracked_entity",
          "child_program_active",
          "child_age_band",
          "child_program_code",
          "reconciliation_ref",
          "tb_program_active"
        ],
        "purpose": "startup-readiness-smoke"
      }
    }
  }
}
