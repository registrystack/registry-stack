# The sidecar image is pure Rust now that the worker execution engine is
# retired. Sources run through the built-in http_json, http_flow, and fhir
# engines, so the image no longer ships Node, npm, or a worker runtime.

# Keep the tag for humans and the digest for reproducible pulls.
FROM rust:1-bookworm@sha256:54152db00aafd37bc5ce1f3585aaa42f17cdd5c8e5ef9eabfbc0718b42bce312 AS builder

WORKDIR /workspace/registry-notary
COPY --from=registry-platform Cargo.toml README.md LICENSE /workspace/registry-platform/
COPY --from=registry-platform crates /workspace/registry-platform/crates
COPY --from=crosswalk Cargo.toml /workspace/crosswalk/
COPY --from=crosswalk crates /workspace/crosswalk/crates
COPY . .

ARG REGISTRY_NOTARY_SOURCE_ADAPTER_SIDECAR_FEATURES=""
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/workspace/target \
    if [ -n "$REGISTRY_NOTARY_SOURCE_ADAPTER_SIDECAR_FEATURES" ]; then \
        CARGO_TARGET_DIR=/workspace/target cargo build --release --locked -p registry-notary-source-adapter-sidecar --bin registry-notary-source-adapter-sidecar --features "$REGISTRY_NOTARY_SOURCE_ADAPTER_SIDECAR_FEATURES"; \
    else \
        CARGO_TARGET_DIR=/workspace/target cargo build --release --locked -p registry-notary-source-adapter-sidecar --bin registry-notary-source-adapter-sidecar; \
    fi \
    && cp /workspace/target/release/registry-notary-source-adapter-sidecar /usr/local/bin/registry-notary-source-adapter-sidecar

# Runtime policy: with the Node worker gone the sidecar is a distroless Rust
# service image, matching the main Notary service runtime: shell-free, non-root,
# JSON-array entrypoint. Liveness and readiness are served over HTTP at
# /healthz and /ready; orchestrators (for example Kubernetes probes) poll those
# endpoints directly, so the image does not bundle a curl/Node container
# healthcheck binary.
FROM gcr.io/distroless/cc-debian12:nonroot@sha256:b0ae8e989418b458e0f25489bc3be523718938a2b70864cc0f6a00af1ddbd985 AS runtime

ENV REGISTRY_NOTARY_SOURCE_ADAPTER_SIDECAR_CONFIG=/etc/registry-notary-source-adapter-sidecar/sidecar.yaml

COPY --from=builder /usr/local/bin/registry-notary-source-adapter-sidecar /usr/local/bin/registry-notary-source-adapter-sidecar

EXPOSE 9191

ENTRYPOINT ["/usr/local/bin/registry-notary-source-adapter-sidecar"]
