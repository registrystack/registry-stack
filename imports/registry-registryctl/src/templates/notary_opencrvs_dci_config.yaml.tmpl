# Generated by registryctl.
server:
  bind: 0.0.0.0:8080
  openapi_requires_auth: false

auth:
  mode: api_key
  api_keys:
    - id: {{evaluator_id}}
      fingerprint:
        provider: env
        name: NOTARY_API_KEY_HASH
        commitment: {{evaluator_commitment}}
      scopes:
        - civil_registry:evidence_verification

audit:
  sink: stdout
  hash_secret_env: NOTARY_AUDIT_SECRET

replay:
  storage: redis
  redis:
    url_env: NOTARY_REPLAY_REDIS_URL
    key_prefix: registryctl-opencrvs-dci-notary

evidence:
  enabled: true
  service_id: registryctl.opencrvs-dci.notary
  api_base_url: http://127.0.0.1:4255
  inline_batch_limit: 10
  source_connections:
    opencrvs_crvs:
      base_url: {{source_url}}
      source_auth:
        type: oauth2_client_credentials
        token_url: {{source_url}}/oauth2/client/token
        client_id_env: DCI_CLIENT_ID
        client_secret_env: DCI_CLIENT_SECRET
        request_format: json
      max_in_flight: 4
      retry_on_5xx: true
      bulk_mode: none
      dci:
        search_path: /registry/sync/search
        sender_id: registry-notary
        query_type: idtype-value
        registry_type: ns:org:RegistryType:Civil
        registry_event_type: birth
        records_path: /message/search_response/0/data/reg_records
  signing_keys:
    {{issuer_key_id}}:
      provider: local_jwk_env
      private_jwk_env: NOTARY_ISSUER_PRIVATE_JWK
      alg: EdDSA
      kid: {{issuer_kid}}
      status: active
  credential_profiles:
    opencrvs_birth_record_sd_jwt:
      format: application/dc+sd-jwt
      issuer: did:web:localhost
      signing_key: {{issuer_key_id}}
      vct: https://localhost/credentials/opencrvs-birth-record/v1
      validity_seconds: 600
      allowed_claims:
        - opencrvs-birth-record-exists
      disclosure:
        allowed:
          - predicate
          - redacted
  claims:
    - id: opencrvs-birth-record-exists
      title: OpenCRVS birth record exists
      version: 2026-06
      subject_type: person
      value:
        type: boolean
      inputs:
        - name: target.identifiers.UIN
          type: string
      source_bindings:
        birth_record:
          connector: dci
          connection: opencrvs_crvs
          required_scope: civil_registry:evidence_verification
          dataset: civil_registry
          entity: birth_registration
          lookup:
            input: target.identifiers.UIN
            field: UIN
            op: eq
            cardinality: one
          fields: {}
          matching:
            policy_id: registryctl.opencrvs-dci.birth-record.lookup.v1
            method: configured_lookup
            sufficient_target_inputs:
              - - target.identifiers.UIN
            allowed_target_inputs:
              - target.identifiers.UIN
            collapse_matching_errors: true
            confidence: high
      rule:
        type: exists
        source: birth_record
      disclosure:
        default: predicate
        allowed:
          - predicate
          - redacted
      formats:
        - application/vnd.registry-notary.claim-result+json
        - application/dc+sd-jwt
      credential_profiles:
        - opencrvs_birth_record_sd_jwt
