                  "status": 401,
                  "title": "Missing credential",
                  "type": "https://data.example.gov/problems/auth/missing_credential"
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "Return the readiness probe",
        "operationId": "getReady",
        "responses": {
          "200": {
            "description": "Evidence runtime is ready",
            "content": {
              "application/json": {
                "example": {
                  "checks": {
                    "failed": 0,
                    "ok": 1,
                    "total": 1
                  },
                  "status": "ready"
                }
              }
            }
          },
          "4XX": {
            "description": "Client error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "request.invalid",
                  "detail": "the evidence request is invalid",
                  "status": 400,
                  "title": "Invalid evidence request",
                  "type": "https://data.example.gov/problems/request/invalid"
                }
              }
            }
          },
          "503": {
            "description": "Evidence runtime is not ready",
            "content": {
              "application/json": {
                "example": {
                  "checks": {
                    "failed": 1,
                    "ok": 0,
                    "total": 1
                  },
                  "status": "not_ready"
                }
              }
            }
          }
        },
        "security": []
      }
    }
  },
