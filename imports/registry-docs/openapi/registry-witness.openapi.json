{
  "openapi": "3.1.0",
  "info": {
    "title": "Registry Witness API",
    "description": "Standalone claim evaluation, rendering, and credential issuance API.",
    "license": {
      "name": "Apache-2.0",
      "identifier": "Apache-2.0"
    },
    "version": "0.2.1"
  },
  "paths": {
    "/.well-known/evidence-service": {
      "get": {
        "summary": "Discover Registry Witness capabilities",
        "operationId": "getEvidenceService",
        "responses": {
          "200": {
            "description": "Service document"
          },
          "401": {
            "description": "Missing or invalid credential"
          }
        }
      }
    },
    "/.well-known/evidence/jwks.json": {
      "get": {
        "summary": "Fetch public issuer verification keys",
        "operationId": "getEvidenceJwks",
        "responses": {
          "200": {
            "description": "Public JWKS"
          },
          "401": {
            "description": "Missing or invalid credential"
          }
        }
      }
    },
    "/admin/reload": {
      "post": {
        "summary": "Request a standalone config reload",
        "operationId": "adminReload",
        "responses": {
          "200": {
            "description": "Reload request accepted; standalone router currently returns a no-op response"
          },
          "401": {
            "description": "Missing or invalid credential"
          },
          "403": {
            "description": "Authenticated principal lacks the admin scope"
          }
        }
      }
    },
    "/claims": {
      "get": {
        "summary": "List claims visible to the caller",
        "operationId": "listClaims",
        "responses": {
          "200": {
            "description": "Visible claims"
          },
          "401": {
            "description": "Missing or invalid credential"
          }
        }
      }
    },
    "/claims/batch-evaluate": {
      "post": {
        "summary": "Evaluate claims for multiple subjects inline",
        "operationId": "batchEvaluateClaims",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchEvaluateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Per-subject claim evaluation results"
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Missing or invalid credential"
          },
          "403": {
            "description": "Not authorized for requested claim, purpose, disclosure, or format"
          }
        }
      }
    },
    "/claims/evaluate": {
      "post": {
        "summary": "Evaluate claims for one subject",
        "operationId": "evaluateClaims",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EvaluateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Claim evaluation result"
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Missing or invalid credential"
          },
          "403": {
            "description": "Not authorized for requested claim, purpose, disclosure, or format"
          }
        }
      }
    },
    "/claims/{claim_id}": {
      "get": {
        "summary": "Get one claim definition",
        "operationId": "getClaim",
        "parameters": [
          {
            "name": "claim_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Claim definition"
          },
          "401": {
            "description": "Missing or invalid credential"
          },
          "404": {
            "description": "Claim not found"
          }
        }
      }
    },
    "/credentials/issue": {
      "post": {
        "summary": "Issue a credential from a stored evaluation",
        "operationId": "issueCredential",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CredentialIssueRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Issued credential"
          },
          "400": {
            "description": "Invalid request or disclosure widening attempt"
          },
          "401": {
            "description": "Missing or invalid credential"
          },
          "404": {
            "description": "Evaluation not found"
          }
        }
      }
    },
    "/evidence/render": {
      "post": {
        "summary": "Render a stored evaluation",
        "operationId": "renderEvidence",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenderRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Rendered evidence artifact"
          },
          "400": {
            "description": "Invalid request or disclosure widening attempt"
          },
          "401": {
            "description": "Missing or invalid credential"
          },
          "404": {
            "description": "Evaluation not found"
          }
        }
      }
    },
    "/formats": {
      "get": {
        "summary": "List supported output formats",
        "operationId": "listFormats",
        "responses": {
          "200": {
            "description": "Supported formats"
          },
          "401": {
            "description": "Missing or invalid credential"
          }
        }
      }
    },
    "/healthz": {
      "get": {
        "summary": "Fetch liveness status",
        "operationId": "getHealthz",
        "responses": {
          "200": {
            "description": "Service is alive"
          }
        },
        "security": []
      }
    },
    "/openapi.json": {
      "get": {
        "summary": "Fetch this OpenAPI document",
        "operationId": "getOpenApi",
        "responses": {
          "200": {
            "description": "OpenAPI document"
          },
          "401": {
            "description": "Missing or invalid credential"
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "Fetch readiness status",
        "operationId": "getReady",
        "responses": {
          "200": {
            "description": "Service is ready"
          },
          "503": {
            "description": "Service is not ready"
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {
      "BatchEvaluateRequest": {
        "type": "object",
        "required": [
          "subjects",
          "claims"
        ],
        "properties": {
          "claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "disclosure": {
            "type": [
              "string",
              "null"
            ]
          },
          "format": {
            "type": [
              "string",
              "null"
            ]
          },
          "purpose": {
            "type": [
              "string",
              "null"
            ]
          },
          "subjects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SubjectRequest"
            }
          }
        },
        "additionalProperties": false
      },
      "CredentialIssueRequest": {
        "type": "object",
        "required": [
          "evaluation_id"
        ],
        "properties": {
          "claims": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          },
          "credential_profile": {
            "type": [
              "string",
              "null"
            ]
          },
          "disclosure": {
            "type": [
              "string",
              "null"
            ]
          },
          "evaluation_id": {
            "type": "string"
          },
          "format": {
            "type": [
              "string",
              "null"
            ]
          },
          "holder": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/HolderRequest"
              }
            ]
          }
        },
        "additionalProperties": false
      },
      "EvaluateRequest": {
        "type": "object",
        "required": [
          "subject",
          "claims"
        ],
        "properties": {
          "claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "disclosure": {
            "type": [
              "string",
              "null"
            ]
          },
          "format": {
            "type": [
              "string",
              "null"
            ]
          },
          "purpose": {
            "type": [
              "string",
              "null"
            ]
          },
          "subject": {
            "$ref": "#/components/schemas/SubjectRequest"
          }
        },
        "additionalProperties": false
      },
      "HolderRequest": {
        "type": "object",
        "properties": {
          "binding": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": [
              "string",
              "null"
            ]
          },
          "proof": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "RenderRequest": {
        "type": "object",
        "required": [
          "evaluation_id",
          "format"
        ],
        "properties": {
          "claims": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          },
          "disclosure": {
            "type": [
              "string",
              "null"
            ]
          },
          "evaluation_id": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "purpose": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "SubjectRequest": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "id_type": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    },
    {
      "bearerAuth": []
    }
  ]
}
