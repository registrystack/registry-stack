{
  "openapi": "3.1.0",
  "info": {
    "title": "Registry Witness API",
    "description": "Standalone claim evaluation, rendering, and credential issuance API.",
    "license": {
      "name": "Apache-2.0",
      "identifier": "Apache-2.0"
    },
    "version": "0.2.1"
  },
  "paths": {
    "/.well-known/evidence-service": {
      "get": {
        "summary": "Discover Registry Witness capabilities",
        "operationId": "getEvidenceService",
        "responses": {
          "200": {
            "description": "Service document",
            "content": {
              "application/json": {
                "example": {
                  "api_version": "2026-05",
                  "auth": {
                    "api_key": {
                      "header": "x-api-key"
                    },
                    "audience": "demo.registry-witness",
                    "bearer": {
                      "format": "Bearer <token>",
                      "header": "Authorization",
                      "scheme": "bearer"
                    },
                    "methods": [
                      "api_key",
                      "bearer"
                    ]
                  },
                  "base_url": "http://127.0.0.1:4255",
                  "batch": {
                    "idempotency_window": "PT15M",
                    "max_inline_subjects": 20
                  },
                  "claims_url": "/claims",
                  "formats": [
                    {
                      "id": "application/dc+sd-jwt",
                      "kind": "credential",
                      "status": "enabled"
                    },
                    {
                      "id": "application/ld+json; profile=\"cccev\"",
                      "kind": "renderer",
                      "status": "enabled"
                    },
                    {
                      "id": "application/vnd.registry-witness.claim-result+json",
                      "kind": "claim_result",
                      "status": "enabled"
                    }
                  ],
                  "formats_url": "/formats",
                  "identity": {
                    "mapper": "common_subject_id",
                    "production_mapper": false
                  },
                  "issuer": {
                    "id": "did:web:agriculture.demo.example.gov",
                    "name": "demo.registry-witness"
                  },
                  "operations": {
                    "batch_evaluate": true,
                    "credential_issue": true,
                    "evaluate": true,
                    "render": true
                  },
                  "service_id": "demo.registry-witness"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid credential",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "auth.missing_credential",
                  "detail": "missing authentication credential",
                  "status": 401,
                  "title": "Missing credential",
                  "type": "https://data.example.gov/problems/auth/missing_credential"
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/evidence/jwks.json": {
      "get": {
        "summary": "Fetch public issuer verification keys",
        "operationId": "getEvidenceJwks",
        "responses": {
          "200": {
            "description": "Public JWKS",
            "content": {
              "application/json": {
                "example": {
                  "keys": [
                    {
                      "alg": "EdDSA",
                      "crv": "Ed25519",
                      "kid": "did:web:agriculture.demo.example.gov#registry-witness-demo-key-1",
                      "kty": "OKP",
                      "x": "11qYAYKxCrfVS_3XDbXJC2AgYI57qXzcS7P0W5Y9f4Y"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid credential",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "auth.missing_credential",
                  "detail": "missing authentication credential",
                  "status": 401,
                  "title": "Missing credential",
                  "type": "https://data.example.gov/problems/auth/missing_credential"
                }
              }
            }
          }
        }
      }
    },
    "/admin/reload": {
      "post": {
        "summary": "Request a standalone config reload",
        "operationId": "adminReload",
        "responses": {
          "200": {
            "description": "Standalone router accepted the reload request",
            "content": {
              "application/json": {
                "example": {
                  "detail": "standalone router has no reloadable external config handle",
                  "reloaded": false,
                  "status": "noop"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid credential",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "auth.missing_credential",
                  "detail": "missing authentication credential",
                  "status": 401,
                  "title": "Missing credential",
                  "type": "https://data.example.gov/problems/auth/missing_credential"
                }
              }
            }
          },
          "403": {
            "description": "Caller lacks registry_witness:admin scope",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "auth.scope_denied",
                  "detail": "missing required scope",
                  "status": 403,
                  "title": "Scope denied",
                  "type": "https://data.example.gov/problems/auth/scope_denied"
                }
              }
            }
          }
        }
      }
    },
    "/claims": {
      "get": {
        "summary": "List claims visible to the caller",
        "operationId": "listClaims",
        "responses": {
          "200": {
            "description": "Visible claims",
            "content": {
              "application/json": {
                "example": {
                  "data": [
                    {
                      "cccev": null,
                      "disclosure": {
                        "allowed": [
                          "value",
                          "redacted"
                        ],
                        "default": "value",
                        "downgrade": "deny"
                      },
                      "formats": [
                        "application/vnd.registry-witness.claim-result+json",
                        "application/ld+json; profile=\"cccev\""
                      ],
                      "id": "date-of-birth",
                      "oots": null,
                      "operations": {
                        "batch_evaluate": false,
                        "evaluate": true
                      },
                      "subject_type": "person",
                      "title": "Date of birth",
                      "version": "2026-05"
                    },
                    {
                      "cccev": {
                        "requirement_type": "InformationRequirement"
                      },
                      "disclosure": {
                        "allowed": [
                          "predicate",
                          "redacted"
                        ],
                        "default": "predicate",
                        "downgrade": "deny"
                      },
                      "formats": [
                        "application/vnd.registry-witness.claim-result+json",
                        "application/ld+json; profile=\"cccev\"",
                        "application/dc+sd-jwt"
                      ],
                      "id": "farmer-under-4ha",
                      "oots": null,
                      "operations": {
                        "batch_evaluate": true,
                        "evaluate": true
                      },
                      "subject_type": "person",
                      "title": "Farmer under four hectares",
                      "version": "2026-05"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid credential",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "auth.missing_credential",
                  "detail": "missing authentication credential",
                  "status": 401,
                  "title": "Missing credential",
                  "type": "https://data.example.gov/problems/auth/missing_credential"
                }
              }
            }
          }
        }
      }
    },
    "/claims/batch-evaluate": {
      "post": {
        "summary": "Evaluate claims for multiple subjects inline",
        "operationId": "batchEvaluateClaims",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchEvaluateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Per-subject claim evaluation results",
            "content": {
              "application/json": {
                "example": {
                  "batch_id": "01HX7Y4N6S7ZK0R2T8Q9V1M3PA",
                  "claims": [
                    "farmer-under-4ha"
                  ],
                  "items": [
                    {
                      "claim_results": [
                        {
                          "claim_id": "farmer-under-4ha",
                          "claim_version": "2026-05",
                          "disclosure": "predicate",
                          "provenance": {
                            "computed_by": "demo.registry-witness",
                            "source_count": 1,
                            "source_versions": {}
                          },
                          "result_id": "01HX7Y5F31M8BZWQ2HY7P6J9FA",
                          "satisfied": true,
                          "value": true,
                          "value_type": "boolean"
                        }
                      ],
                      "errors": [],
                      "evaluation_id": "01HX7Y5F2WAJ7ZP0Q4M5K9E8NC",
                      "input_index": 0,
                      "status": "succeeded",
                      "subject_ref": "person-1"
                    }
                  ],
                  "status": "completed",
                  "summary": {
                    "failed": 0,
                    "succeeded": 1
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "request.invalid",
                  "detail": "the evidence request is invalid",
                  "status": 400,
                  "title": "Invalid evidence request",
                  "type": "https://data.example.gov/problems/request/invalid"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid credential",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "auth.missing_credential",
                  "detail": "missing authentication credential",
                  "status": 401,
                  "title": "Missing credential",
                  "type": "https://data.example.gov/problems/auth/missing_credential"
                }
              }
            }
          },
          "403": {
            "description": "Not authorized for requested claim, purpose, disclosure, or format",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                },
                "example": {
                  "code": "claim.disclosure_not_allowed",
                  "detail": "the requested disclosure profile is not allowed",
                  "status": 403,
                  "title": "Disclosure not allowed",
                  "type": "https://data.example.gov/problems/claim/disclosure_not_allowed"
                }
              }
            }
          }
        }
      }
    },
