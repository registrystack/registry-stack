---
import config from 'virtual:starlight/user-config';
import Search from '@astrojs/starlight/components/Search.astro';
import docsetsManifest from '../data/generated/docsets.json';

const base = import.meta.env.BASE_URL;
const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const activeDocsetId = process.env.DOCS_DOCSET || docsetsManifest.current;
const activeDocset =
  docsetsManifest.docsets.find((docset) => docset.id === activeDocsetId) ??
  docsetsManifest.docsets.find((docset) => docset.id === docsetsManifest.current);

function pathForDocset(targetPath: string) {
  const currentPath = Astro.url.pathname;
  const activePath = activeDocset?.path ?? '/';
  const relativePath =
    activePath !== '/' && currentPath.startsWith(activePath)
      ? currentPath.slice(activePath.length)
      : currentPath.replace(/^\//, '');
  return `${targetPath}${relativePath}`.replace(/\/{2,}/g, '/');
}
---

<div class="registry-header">
  <div class="registry-masthead">
    <a class="registry-wordmark" href={base}>
      <span class="registry-brand-mark" aria-hidden="true">RS</span>
      <span>Registry Stack</span>
      <span class="registry-docs-tag">Docs</span>
      <span class="registry-version">{activeDocset?.label}</span>
    </a>

    {shouldRenderSearch && (
      <div class="registry-search">
        <span class="registry-search-label" id="registry-search-label">Search</span>
        <Search />
      </div>
    )}

    <nav class="registry-utility" aria-label="Site">
      <label class="registry-version-switch">
        <span>Version</span>
        <select aria-label="Docs version" onchange="if (this.value) window.location.href = this.value">
          {docsetsManifest.docsets.map((docset) => (
            <option value={pathForDocset(docset.path)} selected={docset.id === activeDocset?.id}>
              {docset.label}
            </option>
          ))}
        </select>
      </label>
      <a href="https://github.com/jeremi/registry-docs">GitHub ↗</a>
    </nav>
  </div>
</div>
