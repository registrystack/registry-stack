---
import docsetsManifest from '../data/generated/docsets.json';
import { mdHrefForPath } from '../lib/md-href';

const activeDocsetId = process.env.DOCS_DOCSET || docsetsManifest.current;
const activeDocset =
  docsetsManifest.docsets.find((docset) => docset.id === activeDocsetId) ??
  docsetsManifest.docsets.find((docset) => docset.id === docsetsManifest.current);
const isArchived = activeDocset?.status === 'archived';
const head = isArchived
  ? Astro.locals.starlightRoute.head.filter(
      ({ tag, attrs }) => !(tag === 'link' && attrs?.rel === 'sitemap'),
    )
  : Astro.locals.starlightRoute.head;

// Machine-discoverability: the .md alternate link tells LLMs and other
// consumers where to find the raw Markdown source for this page.
const mdHref = mdHrefForPath(Astro.url.pathname, import.meta.env.BASE_URL);
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
{isArchived && <meta name="robots" content="noindex,follow" />}
<link rel="alternate" type="text/markdown" href={mdHref} />
