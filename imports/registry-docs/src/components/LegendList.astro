---
import projects from '../data/generated/projects.json';

const base = import.meta.env.BASE_URL;
const descriptions = new Map([
  ['registry-manifest', 'Describe a registry once; publish everything other systems need to find, understand, and connect to it.'],
  ['registry-relay', 'Let authorized systems query a registry over HTTP, without giving them database access or write paths.'],
  ['registry-witness', 'Prove a person qualifies for a program without sharing the records that prove it.'],
  ['registry-atlas', 'Explore what a registry publishes (data, schemas, rules) in your browser before you integrate.'],
  ['registry-lab', 'Run the whole family together on your laptop in one command, with fixtures and a narrated walk-through.'],
]);
---

<ol class="legend-list">
  {projects.map((project, index) => (
    <li id={project.id}>
      <a href={`${base}projects/${project.id}/`}>
        <span class="legend-index">{index + 1}.</span>
        <span class="legend-project">
          <span>{project.name}</span>
          <code>{project.id}</code>
        </span>
        <span class="legend-description">{descriptions.get(project.id) ?? project.role}</span>
      </a>
    </li>
  ))}
</ol>
