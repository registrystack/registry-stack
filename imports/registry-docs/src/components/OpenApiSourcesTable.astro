---
import sources from '../data/generated/openapi-sources.json';
---

<div class="registry-table">
  <table>
    <thead>
      <tr>
        <th>API</th>
        <th>Owner</th>
        <th>Status</th>
        <th>Source</th>
        <th>Pinned artifact</th>
        <th>Redoc</th>
      </tr>
    </thead>
    <tbody>
      {sources.map((source) => (
        <tr>
          <td>
            <strong>{source.name}</strong><br />
            <code>{source.id}</code>
          </td>
          <td>{source.owner}</td>
          <td><span class="status-chip">{source.status}</span></td>
          <td>{source.source}</td>
          <td><code>{source.artifact}</code></td>
          <td><a href={source.redoc_path}>Open Redoc page</a></td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
<p class="source-note">Generated from <code>src/data/openapi-sources.yaml</code>.</p>
