meta {
  name: Verify-only key cannot read student rows (expects 403)
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/datasets/education_registry/student?id={{studentAlias}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{verifyKey}}
}

headers {
  Data-Purpose: {{purpose}}
}

docs {
  Attempts to read student rows using verifyKey.
  verifyKey holds only education_registry:verify; row reads require :rows.
  expected: 403 auth.scope_denied
}
