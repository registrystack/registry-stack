meta {
  name: Link-free OGC records
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/metadata/ogc/records
  body: none
  auth: bearer
}

auth:bearer {
  token: {{metadataKey}}
}

docs {
  Reads link-free OGC API Records bodies generated by registry-metadata-core.
  Uses catalog_viewer persona (metadataKey).
  Expected: 200 with one record body per visible dataset, without runtime-injected absolute links.
}
