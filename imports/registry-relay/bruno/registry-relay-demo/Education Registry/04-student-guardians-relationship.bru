meta {
  name: Read student guardians relationship
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/v1/datasets/education_registry/entities/student/records/{{studentAlias}}/relationships/guardians
  body: none
  auth: bearer
}

auth:bearer {
  token: {{rowsKey}}
}

headers {
  Data-Purpose: {{purpose}}
}

docs {
  Reads the guardians relationship for student stu-2001 as a paginated list.
  Uses casework_system persona (rowsKey). Purpose header required (guardian has PII).
  Expected: 200 with guardian records showing guardian_id, relationship, contact_verified.
  Sensitive fields guardian_name, phone, email, address are absent.
}
