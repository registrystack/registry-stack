meta {
  name: Clinic facility feature
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/ogc/v1/datasets/clinic_capacity/collections/facilities/items/{{facilityId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{rowsKey}}
}

docs {
  Reads one clinic facility as a GeoJSON Feature.
  Expected: 200 application/geo+json with a self link and collection link.
}
