{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fixture.example/schemas/verify-result/v1.json",
  "title": "VerifyResult v1 fixture schema",
  "type": "object",
  "required": ["dataset", "entity", "subjectId", "predicate", "value", "asOf"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "dataset": {
      "type": "string",
      "minLength": 1
    },
    "entity": {
      "type": "string",
      "minLength": 1
    },
    "subjectId": {
      "type": "string",
      "minLength": 1
    },
    "predicate": {
      "type": "string",
      "minLength": 1
    },
    "value": {
      "type": ["boolean", "string", "number", "null"]
    },
    "asOf": {
      "type": "string",
      "format": "date-time"
    }
  }
}
