@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

<https://data-gate.dev/shapes/DcatCatalogSmokeShape>
    a sh:NodeShape ;
    sh:targetClass dcat:Catalog ;
    sh:property [
        sh:path dcterms:title ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
    ] ;
    sh:property [
        sh:path dcterms:publisher ;
        sh:minCount 1 ;
        sh:class foaf:Agent ;
    ] ;
    sh:property [
        sh:path dcat:dataset ;
        sh:minCount 1 ;
        sh:class dcat:Dataset ;
    ] .

<https://data-gate.dev/shapes/DcatDatasetSmokeShape>
    a sh:NodeShape ;
    sh:targetClass dcat:Dataset ;
    sh:property [
        sh:path dcterms:title ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
    ] ;
    sh:property [
        sh:path dcterms:description ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
    ] ;
    sh:property [
        sh:path dcterms:publisher ;
        sh:minCount 1 ;
        sh:class foaf:Agent ;
    ] ;
    sh:property [
        sh:path dcterms:accessRights ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path dcterms:accrualPeriodicity ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path dcat:distribution ;
        sh:minCount 1 ;
        sh:class dcat:Distribution ;
    ] .

<https://data-gate.dev/shapes/DcatDistributionSmokeShape>
    a sh:NodeShape ;
    sh:targetClass dcat:Distribution ;
    sh:property [
        sh:path dcterms:title ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
    ] ;
    sh:property [
        sh:path dcat:accessURL ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
    ] .

<https://data-gate.dev/shapes/EmbeddedNodeShapeSmokeShape>
    a sh:NodeShape ;
    sh:targetClass sh:NodeShape ;
    sh:property [
        sh:path sh:targetClass ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path sh:property ;
        sh:minCount 1 ;
        sh:class sh:PropertyShape ;
    ] .

<https://data-gate.dev/shapes/EmbeddedPropertyShapeSmokeShape>
    a sh:NodeShape ;
    sh:targetClass sh:PropertyShape ;
    sh:property [
        sh:path sh:path ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path sh:name ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
    ] .
