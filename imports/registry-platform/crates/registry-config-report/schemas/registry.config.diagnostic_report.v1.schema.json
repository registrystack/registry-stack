{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry-platform.example/schemas/registry.config.diagnostic_report.v1.schema.json",
  "title": "Registry Product Config Diagnostic Report v1",
  "type": "object",
  "required": [
    "schema_version",
    "product",
    "config_schema_version",
    "source",
    "status",
    "summary",
    "diagnostics",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "registry.config.diagnostic_report.v1"
    },
    "product": {
      "$ref": "#/$defs/non_empty_string"
    },
    "config_schema_version": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "status": {
      "$ref": "#/$defs/report_status"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "required_env": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/required_env"
      },
      "default": []
    },
    "hashes": {
      "$ref": "#/$defs/hashes"
    },
    "generated_at": {
      "$ref": "#/$defs/rfc3339_timestamp"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "rfc3339_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "sha256_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "report_status": {
      "enum": ["ok", "warning", "error", "not_run"]
    },
    "severity": {
      "enum": ["info", "warning", "error"]
    },
    "classification": {
      "enum": ["public", "secret", "topology_sensitive", "internal_only"]
    },
    "env_status": {
      "enum": ["present", "missing", "not_checked"]
    },
    "source": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "local_file",
            "generated_file",
            "signed_bundle_file",
            "signed_bundle_endpoint",
            "unknown"
          ]
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "uri": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["error_count", "warning_count"],
      "additionalProperties": false,
      "properties": {
        "error_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/$defs/non_empty_string"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "message": {
          "$ref": "#/$defs/non_empty_string"
        },
        "replacement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "documentation_key": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "required_env": {
      "type": "object",
      "required": ["name", "classification", "status"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "classification": {
          "$ref": "#/$defs/classification"
        },
        "status": {
          "$ref": "#/$defs/env_status"
        }
      }
    },
    "hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "internal_config_hash": {
          "$ref": "#/$defs/sha256_hash"
        },
        "posture_safe_config_hash": {
          "$ref": "#/$defs/sha256_hash"
        }
      }
    }
  }
}
