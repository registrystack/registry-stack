{
  "name": "registry-stack",
  "displayName": "Registry Stack",
  "description": "Cross-file navigation and reference diagnostics for Registry Stack YAML projects.",
  "version": "0.1.0",
  "publisher": "registrystack",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/registrystack/registry-stack"
  },
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "registry-stack",
    "yaml",
    "language-server"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:registry-stack.yaml",
    "onCommand:registryStack.restartLanguageServer"
  ],
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Registry Stack starts a local executable and reads project files from disk. Trust the workspace before enabling it."
    },
    "virtualWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "registryStack.restartLanguageServer",
        "title": "Registry Stack: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "Registry Stack",
      "properties": {
        "registryStack.languageServer.path": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Path to the registry-language-server executable. Relative paths resolve from the Registry Stack project root. When empty, the extension searches PATH, then runs `registryctl authoring language-server` from PATH."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --platform=node --target=node20 --external:vscode --outfile=dist/extension.js --sourcemap --minify",
    "compile-tests": "tsc -p tsconfig.test.json",
    "check": "tsc -p . --noEmit && tsc -p tsconfig.test.json --noEmit",
    "package:dev": "npm run check && npm run compile && vsce package --no-dependencies --out registry-stack-dev.vsix && npm run verify:package",
    "verify:package": "node scripts/verify-vsix.cjs registry-stack-dev.vsix",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "vscode-test",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "1.91.0",
    "@vscode/test-cli": "0.0.15",
    "@vscode/test-electron": "3.0.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "diff": "8.0.3",
    "serialize-javascript": "7.0.7"
  }
}
