# Release packaging image for the source-adapter sidecar binary. The OpenFn
# engine is retired, but the historical image and binary name remain stable for
# lab compatibility.

FROM node:26-bookworm-slim@sha256:b16ca7b4dcfb20184e1c70f9ee30c6a75ed1da669cfafd6d2add4761b123d79f AS runtime

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/openfn
COPY --chmod=0755 dist/image-bin/registry-notary-openfn-sidecar /usr/local/bin/registry-notary-openfn-sidecar
COPY lab/config/openfn/mock-registry-server.mjs ./mock-registry-server.mjs

USER node
EXPOSE 8080

ENTRYPOINT ["registry-notary-openfn-sidecar"]
