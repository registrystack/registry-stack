#!/usr/bin/env python3
"""RegistryStack release manifest validator and import auditor."""

from __future__ import annotations

import argparse
import hashlib
import json
import re
import shutil
import subprocess
import sys
from pathlib import Path

import yaml


ROOT = Path(__file__).resolve().parents[2]
RELEASE_MANIFEST_DIR = ROOT / "release" / "manifests"
DOCSETS_PATH = ROOT / "docs" / "site" / "src" / "data" / "docsets.yaml"
HEX40 = re.compile(r"^[0-9a-f]{40}$")
SHA256_HEX = re.compile(r"^[0-9a-f]{64}$")
SEMVER_TAG = re.compile(r"^v[0-9]+\.[0-9]+\.[0-9]+$")
IMAGE_DIGEST_REF = re.compile(r"^([^@]+)@(sha256:[0-9a-f]{64})$")
RELEASE_IMAGE_LOCK_SCHEMA = "registryctl.release_image_lock.v1"
RELEASE_IMAGE_LOCK_PLATFORM = "linux/amd64"
RELEASE_IMAGE_LOCK_MINIMUM_VERSION = (0, 9, 0)
RELEASE_IMAGE_LOCK_REPOSITORIES = {
    "registry-relay": "ghcr.io/registrystack/registry-relay",
    "registry-notary": "ghcr.io/registrystack/registry-notary",
}


def release_version_tuple(version: str) -> tuple[int, int, int] | None:
    if re.fullmatch(r"[0-9]+\.[0-9]+\.[0-9]+", version) is None:
        return None
    return tuple(int(part) for part in version.split("."))


def require_registryctl_image_lock_release_version(version: str) -> None:
    parsed = release_version_tuple(version)
    if parsed is None:
        raise ValueError(
            "registryctl image lock release version must be semantic version text, "
            f"got {version!r}"
        )
    if parsed < RELEASE_IMAGE_LOCK_MINIMUM_VERSION:
        raise ValueError("registryctl image lock releases require version 0.9.0 or later")


def verify_registryctl_image_lock_release_version(version: str) -> int:
    try:
        require_registryctl_image_lock_release_version(version)
    except ValueError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    print(f"verified registryctl image lock release version {version}")
    return 0


def load_yaml(path: Path) -> object:
    with path.open("r", encoding="utf-8") as handle:
        return yaml.safe_load(handle)


def load_json(path: Path) -> object:
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def read_release_image_digest(path: Path, image_name: str) -> str:
    if path.is_symlink() or not path.is_file():
        raise ValueError(f"{image_name} digest evidence must be a regular file: {path}")
    if path.stat().st_size > 1024:
        raise ValueError(f"{image_name} digest evidence exceeds 1024 bytes: {path}")
    body = path.read_text(encoding="utf-8")
    lines = body.splitlines()
    if len(lines) != 1 or body not in {lines[0], f"{lines[0]}\n"}:
        raise ValueError(f"{image_name} digest evidence must contain exactly one unpadded line")
    digest_ref = lines[0]
    match = IMAGE_DIGEST_REF.fullmatch(digest_ref)
    if match is None:
        raise ValueError(f"{image_name} digest ref must match image@sha256:<64 lowercase hex>")
    expected_repository = RELEASE_IMAGE_LOCK_REPOSITORIES[image_name]
    if match.group(1) != expected_repository:
        raise ValueError(
            f"{image_name} digest ref repository must be {expected_repository}, got {match.group(1)}"
        )
    return digest_ref


def render_registryctl_image_lock(
    manifest_path: Path,
    relay_digest_path: Path,
    notary_digest_path: Path,
    tag_target: str,
    output: Path,
) -> int:
    try:
        manifest = load_yaml(manifest_path)
        if not isinstance(manifest, dict) or not isinstance(manifest.get("stack"), dict):
            raise ValueError("release manifest stack must be an object")
        stack = manifest["stack"]
        version = str(stack.get("version", ""))
        require_registryctl_image_lock_release_version(version)
        release_tag = str(stack.get("source_tag", ""))
        if release_tag != f"v{version}":
            raise ValueError(f"manifest stack.source_tag must be v{version}")
        manifest_source_ref = str(stack.get("source_ref", ""))
        if HEX40.fullmatch(manifest_source_ref) is None:
            raise ValueError("manifest stack.source_ref must be 40 lowercase hexadecimal characters")
        if HEX40.fullmatch(tag_target) is None:
            raise ValueError("tag target must be 40 lowercase hexadecimal characters")
        expected_name = f"registryctl-v{version}-image-lock.json"
        if output.name != expected_name:
            raise ValueError(f"image lock output filename must be {expected_name}")
        if output.is_symlink() or (output.exists() and not output.is_file()):
            raise ValueError(f"image lock output must be a regular file path: {output}")

        relay_digest = read_release_image_digest(relay_digest_path, "registry-relay")
        notary_digest = read_release_image_digest(notary_digest_path, "registry-notary")
        image_lock = {
            "schema_version": RELEASE_IMAGE_LOCK_SCHEMA,
            "release_tag": release_tag,
            "manifest_source_ref": manifest_source_ref,
            "tag_target": tag_target,
            "platform": RELEASE_IMAGE_LOCK_PLATFORM,
            "images": {
                "registry-relay": relay_digest,
                "registry-notary": notary_digest,
            },
        }
        output.parent.mkdir(parents=True, exist_ok=True)
        output.write_text(json.dumps(image_lock, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    except (KeyError, OSError, UnicodeError, ValueError, yaml.YAMLError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1

    print(f"rendered registryctl release image lock {output}")
    return 0


def validate_registryctl_image_lock_document(
    data: object,
    *,
    version: str,
    release_tag: str,
    manifest_source_ref: str,
    tag_target: str,
) -> None:
    if not isinstance(data, dict):
        raise ValueError("registryctl release image lock must be a JSON object")
    expected_keys = {
        "schema_version",
        "release_tag",
        "manifest_source_ref",
        "tag_target",
        "platform",
        "images",
    }
    if set(data) != expected_keys:
        raise ValueError("registryctl release image lock has missing or unknown top-level fields")
    expected_values = {
        "schema_version": RELEASE_IMAGE_LOCK_SCHEMA,
        "release_tag": release_tag,
        "manifest_source_ref": manifest_source_ref,
        "tag_target": tag_target,
        "platform": RELEASE_IMAGE_LOCK_PLATFORM,
    }
    for field, expected in expected_values.items():
        if data.get(field) != expected:
            raise ValueError(f"registryctl release image lock {field} must be {expected!r}")
    images = data.get("images")
    if not isinstance(images, dict) or set(images) != set(RELEASE_IMAGE_LOCK_REPOSITORIES):
        raise ValueError("registryctl release image lock images has missing or unknown fields")
    for image_name, repository in RELEASE_IMAGE_LOCK_REPOSITORIES.items():
        digest_ref = images.get(image_name)
        match = IMAGE_DIGEST_REF.fullmatch(digest_ref) if isinstance(digest_ref, str) else None
        if match is None or match.group(1) != repository:
            raise ValueError(
                f"registryctl release image lock {image_name} must be {repository}@sha256:<64 lowercase hex>"
            )
    if data["release_tag"] != f"v{version}":
        raise ValueError(f"registryctl release image lock release_tag must match v{version}")


def verify_registryctl_binary_version(binary: Path, version: str) -> int:
    if re.fullmatch(r"[0-9]+\.[0-9]+\.[0-9]+", version) is None:
        print(f"error: expected registryctl version must be semantic version text, got {version!r}", file=sys.stderr)
        return 1
    if binary.is_symlink() or not binary.is_file():
        print(f"error: registryctl binary must be a regular file: {binary}", file=sys.stderr)
        return 1
    try:
        result = subprocess.run(
            [str(binary.resolve()), "--version"],
            text=True,
            capture_output=True,
            timeout=10,
            check=False,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        print(f"error: failed to execute registryctl binary {binary}: {exc}", file=sys.stderr)
        return 1
    expected = f"registryctl {version}"
    if result.returncode != 0:
        print(
            f"error: registryctl binary --version exited {result.returncode}: {result.stderr.strip()}",
            file=sys.stderr,
        )
        return 1
    if result.stderr or result.stdout != f"{expected}\n":
        print(
            f"error: registryctl binary version must be exactly {expected!r}, got {result.stdout.strip()!r}",
            file=sys.stderr,
        )
        return 1
    print(f"verified registryctl binary version {version}: {binary}")
    return 0


def copy_required_asset(asset_dir: Path, name: str, output_dir: Path) -> None:
    source = asset_dir / name
    if not source.is_file():
        raise FileNotFoundError(f"missing release asset {name}")
    output_dir.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, output_dir / name)


def copy_optional_asset(asset_dir: Path, name: str, output_dir: Path) -> bool:
    source = asset_dir / name
    if not source.is_file():
        return False
    output_dir.mkdir(parents=True, exist_ok=True)
    shutil.copy2(source, output_dir / name)
    return True


def stage_capsule_backfill_assets(asset_dir: Path, tag: str, binary_dir: Path, image_evidence_dir: Path) -> int:
    if SEMVER_TAG.fullmatch(tag) is None:
        print(f"error: release tag must look like v0.8.0, got {tag}", file=sys.stderr)
        return 1
    if not asset_dir.is_dir():
        print(f"error: release asset directory does not exist: {asset_dir}", file=sys.stderr)
        return 1

    binary_names = [
        f"registryctl-{tag}-linux-amd64",
        f"registry-manifest-{tag}-linux-amd64",
        f"registry-relay-{tag}-linux-amd64",
        f"registry-notary-{tag}-linux-amd64",
        "SHA256SUMS",
    ]
    # These binaries were introduced after the earliest supported release
    # tags. Keep them optional so historical capsule backfills remain possible.
    optional_binary_names = [
        f"registryctl-{tag}-macos-arm64",
        f"registryctl-{tag}-linux-arm64",
        f"registry-relay-rhai-worker-{tag}-linux-amd64",
    ]
    optional_release_file_names = [f"registryctl-{tag}-image-lock.json"]
    image_names = [
        "registry-notary",
        "registry-notary-source-adapter-sidecar",
        "registry-relay",
    ]

    staged_optional: list[str] = []
    staged_release_files: list[str] = []
    try:
        for name in binary_names:
            copy_required_asset(asset_dir, name, binary_dir)
        for name in optional_binary_names:
            if copy_optional_asset(asset_dir, name, binary_dir):
                staged_optional.append(name)
        for name in optional_release_file_names:
            if copy_optional_asset(asset_dir, name, binary_dir):
                staged_release_files.append(name)
        for image in image_names:
            copy_required_asset(asset_dir, f"{image}.digest", image_evidence_dir)
    except OSError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1

    print(
        f"staged {len(binary_names)} binary assets "
        f"({len(staged_optional)}/{len(optional_binary_names)} optional cross-platform) "
        f"and {len(staged_release_files)}/{len(optional_release_file_names)} optional release files "
        f"and {len(image_names)} image digest assets for {tag}"
    )
    for name in optional_binary_names:
        print(f"  optional binary {name}: {'staged' if name in staged_optional else 'absent (skipped)'}")
    for name in optional_release_file_names:
        print(
            f"  optional release file {name}: "
            f"{'staged' if name in staged_release_files else 'absent (skipped)'}"
        )
    return 0


def validate(manifest_path: Path) -> int:
    manifest = load_yaml(manifest_path)
    errors: list[str] = []
    stack = manifest.get("stack", {}) if isinstance(manifest, dict) else {}
    artifacts = manifest.get("artifacts", {}) if isinstance(manifest, dict) else {}
    external = manifest.get("external", {}) if isinstance(manifest, dict) else {}
    version = str(stack.get("version", ""))
    source_ref = str(stack.get("source_ref", ""))
    source_tag = str(stack.get("source_tag", ""))
    status = str(stack.get("status", ""))

    if stack.get("source_repo") != "registrystack/registry-stack":
        errors.append("stack.source_repo must be registrystack/registry-stack")
    if not version:
        errors.append("stack.version is required")
    if source_tag != f"v{version}":
        errors.append(f"stack.source_tag must be v{version}")
    if source_ref != "HEAD" and not HEX40.fullmatch(source_ref):
        errors.append("stack.source_ref must be HEAD for a draft or a 40-character commit")
    if source_ref == "HEAD" and status != "draft":
        errors.append("stack.source_ref may be HEAD only when stack.status is draft")
    parsed_version = release_version_tuple(version)
    if (
        parsed_version is not None
        and parsed_version >= RELEASE_IMAGE_LOCK_MINIMUM_VERSION
        and "registryctl-image-lock" not in artifacts
    ):
        errors.append("artifact registryctl-image-lock is required for version 0.9.0 or later")
    for name, artifact_version in sorted(artifacts.items()):
        if str(artifact_version) != version:
            errors.append(f"artifact {name} version {artifact_version} does not match stack version {version}")
    crosswalk = external.get("crosswalk", {}) if isinstance(external, dict) else {}
    if crosswalk.get("repo") != "PublicSchema/crosswalk":
        errors.append("external.crosswalk.repo must be PublicSchema/crosswalk")
    if not HEX40.fullmatch(str(crosswalk.get("ref", ""))):
        errors.append("external.crosswalk.ref must be a 40-character commit")

    if errors:
        for error in errors:
            print(f"error: {error}", file=sys.stderr)
        return 1
    print(f"validated {manifest_path}: {stack.get('release')} {version}")
    return 0


def validate_docsets(manifest_dir: Path, docsets_path: Path) -> int:
    errors: list[str] = []
    try:
        docsets_data = load_yaml(docsets_path)
        manifests = [
            load_yaml(path)
            for path in sorted(manifest_dir.glob("registry-stack-*.yaml"))
        ]
    except (OSError, UnicodeError, yaml.YAMLError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1

    docsets = docsets_data.get("docsets", []) if isinstance(docsets_data, dict) else []
    if not isinstance(docsets, list):
        print("error: docsets.yaml docsets must be a list", file=sys.stderr)
        return 1

    manifests_by_tag: dict[str, dict] = {}
    for manifest in manifests:
        if not isinstance(manifest, dict) or not isinstance(manifest.get("stack"), dict):
            errors.append("release manifest must contain a stack object")
            continue
        source_tag = manifest["stack"].get("source_tag")
        if isinstance(source_tag, str):
            if source_tag in manifests_by_tag:
                errors.append(f"multiple release manifests declare {source_tag}")
            manifests_by_tag[source_tag] = manifest

    checked = 0
    for docset in docsets:
        if not isinstance(docset, dict):
            continue
        docset_id = str(docset.get("id", ""))
        if SEMVER_TAG.fullmatch(docset_id) is None:
            continue
        source = docset.get("source")
        expected_source = f"registry-stack-{docset_id}"
        if source != expected_source:
            errors.append(
                f"docset {docset_id} source {source!r} must be {expected_source!r}"
            )
        manifest = manifests_by_tag.get(docset_id)
        if manifest is None:
            errors.append(f"docset {docset_id} has no release manifest for {docset_id}")
            continue

        stack = manifest["stack"]
        products = docset.get("products")
        if not isinstance(products, dict):
            errors.append(f"docset {docset_id} products must be an object")
            continue

        external = manifest.get("external")
        if not isinstance(external, dict):
            errors.append(f"release manifest {docset_id} external must be an object")
            continue
        expected_source_ref = stack.get("source_ref")
        expected_version = f"v{stack.get('version')}"
        for name, product in sorted(products.items()):
            if name in external:
                continue
            actual_ref = product.get("ref") if isinstance(product, dict) else None
            actual_version = product.get("version") if isinstance(product, dict) else None
            if actual_ref != expected_source_ref:
                errors.append(
                    f"docset {docset_id} product {name} ref {actual_ref!r} "
                    f"does not match release manifest ref {expected_source_ref!r}"
                )
            if actual_version != expected_version:
                errors.append(
                    f"docset {docset_id} product {name} version {actual_version!r} "
                    f"does not match release manifest version {expected_version!r}"
                )
        for name, expected in sorted(external.items()):
            if not isinstance(expected, dict):
                errors.append(
                    f"release manifest {docset_id} external {name} must be an object"
                )
                continue
            expected_ref = expected.get("ref")
            product = products.get(name)
            actual_ref = product.get("ref") if isinstance(product, dict) else None
            if actual_ref != expected_ref:
                errors.append(
                    f"docset {docset_id} external {name} ref {actual_ref!r} "
                    f"does not match release manifest ref {expected_ref!r}"
                )
        checked += 1

    if errors:
        for error in errors:
            print(f"error: {error}", file=sys.stderr)
        return 1
    if checked == 0:
        print("error: no versioned docsets matched release manifests", file=sys.stderr)
        return 1
    print(f"validated {checked} versioned docsets against release manifests")
    return 0


def git(repo: Path, *args: str, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", *args],
        cwd=repo,
        text=True,
        capture_output=True,
        check=check,
    )


def is_draft_source(manifest: dict) -> bool:
    stack = manifest.get("stack", {}) if isinstance(manifest, dict) else {}
    if stack.get("status") == "draft" or stack.get("source_ref") == "HEAD":
        return True
    warnings = manifest.get("warnings", []) if isinstance(manifest, dict) else []
    return any(isinstance(warning, dict) and warning.get("code") == "draft-source-ref" for warning in warnings)


def source_lineage(manifest: dict, tag: str, repo: Path, default_branch: str) -> tuple[list[str], dict]:
    errors: list[str] = []
    stack = manifest.get("stack", {})
    source_tag = str(stack.get("source_tag", ""))
    source_ref = str(stack.get("source_ref", ""))
    draft = is_draft_source(manifest)
    proof = {
        "source_tag": source_tag,
        "source_ref": source_ref,
        "source_commit": "",
        "manifest_ref": source_ref,
        "lineage": {
            "tag_matches_source_tag": False,
            "head_matches_tag_target": False,
            "source_ref_ancestor_or_equal": False,
            "default_branch_reachable": False,
        },
    }

    if not source_tag:
        errors.append("stack.source_tag is required")
    elif source_tag != tag:
        errors.append(f"stack.source_tag {source_tag} does not match checked-out release tag {tag}")
    else:
        proof["lineage"]["tag_matches_source_tag"] = True

    tag_result = git(repo, "rev-parse", "--verify", f"refs/tags/{tag}^{{}}", check=False)
    if tag_result.returncode != 0:
        errors.append(f"release tag {tag} does not exist")
        tag_target = ""
    else:
        tag_target = tag_result.stdout.strip()
        head = git(repo, "rev-parse", "HEAD").stdout.strip()
        proof["source_commit"] = head
        if head != tag_target:
            errors.append(f"checked-out HEAD {head} does not match release tag target {tag_target}")
        else:
            proof["lineage"]["head_matches_tag_target"] = True

    if not draft and tag_target:
        if not HEX40.fullmatch(source_ref):
            errors.append("stack.source_ref must be a 40-character commit for a non-draft release")
        else:
            ancestor = git(repo, "merge-base", "--is-ancestor", source_ref, tag_target, check=False)
            if ancestor.returncode != 0:
                errors.append(f"stack.source_ref {source_ref} is not an ancestor of release tag target {tag_target}")
            else:
                proof["lineage"]["source_ref_ancestor_or_equal"] = True

        reachable = git(repo, "merge-base", "--is-ancestor", tag_target, default_branch, check=False)
        if reachable.returncode != 0:
            errors.append(f"release tag target {tag_target} is not reachable from {default_branch}")
        else:
            proof["lineage"]["default_branch_reachable"] = True
    elif draft and source_ref not in {"HEAD", ""} and tag_target:
        if not HEX40.fullmatch(source_ref):
            errors.append("stack.source_ref must be HEAD for a draft or a 40-character commit")
        else:
            ancestor = git(repo, "merge-base", "--is-ancestor", source_ref, tag_target, check=False)
            proof["lineage"]["source_ref_ancestor_or_equal"] = ancestor.returncode == 0

    return errors, proof


def validate_source(manifest_path: Path, tag: str, repo: Path, default_branch: str) -> int:
    manifest = load_yaml(manifest_path)
    if not isinstance(manifest, dict):
        print("error: release manifest must be an object", file=sys.stderr)
        return 1
    errors, proof = source_lineage(manifest, tag, repo, default_branch)
    if errors:
        for error in errors:
            print(f"error: {error}", file=sys.stderr)
        return 1
    print(f"validated source lineage for {tag}: {proof['source_ref']} -> {proof['source_commit'] or 'draft'}")
    return 0


def find_one(root: Path, pattern: str) -> Path | None:
    matches = sorted(path for path in root.rglob(pattern) if path.is_file())
    return matches[0] if matches else None


def find_image_evidence(root: Path, name: str, suffix: str) -> Path | None:
    return find_one(root, f"{name}.digest-bound{suffix}") or find_one(root, f"{name}{suffix}")


def severity_summary(grype_report: object) -> dict[str, int]:
    summary = {"critical": 0, "high": 0, "medium": 0, "low": 0, "negligible": 0, "unknown": 0}
    matches = grype_report.get("matches", []) if isinstance(grype_report, dict) else []
    for match in matches:
        vulnerability = match.get("vulnerability", {}) if isinstance(match, dict) else {}
        severity = str(vulnerability.get("severity", "unknown")).lower()
        summary[severity if severity in summary else "unknown"] += 1
    return summary


def release_decision_status(summary: dict[str, int]) -> str:
    if summary.get("critical", 0) or summary.get("high", 0):
        return "review-required"
    return "no-high-or-critical-findings"


def nested(data: object, *keys: str) -> object:
    current = data
    for key in keys:
        if not isinstance(current, dict):
            return None
        current = current.get(key)
    return current


def grype_subject(report: object) -> str | None:
    for keys in (
        ("source", "target", "userInput"),
        ("source", "target", "imageID"),
        ("source", "target", "manifestDigest"),
    ):
        value = nested(report, *keys)
        if isinstance(value, str) and value:
            return value
    repo_digests = nested(report, "source", "target", "repoDigests")
    if isinstance(repo_digests, list) and repo_digests:
        return str(repo_digests[0])
    return None


def field_contains_digest(value: object, digest_ref: str, digest: str) -> bool:
    return isinstance(value, str) and (digest_ref in value or digest in value)


def spdx_subject_contains_digest(data: object, digest_ref: str, digest: str) -> bool:
    if not isinstance(data, dict):
        return False
    described = data.get("documentDescribes")
    packages = data.get("packages")
    if not isinstance(described, list) or not isinstance(packages, list):
        return False
    described_ids = {item for item in described if isinstance(item, str)}
    if not described_ids:
        return False
    for package in packages:
        if not isinstance(package, dict) or package.get("SPDXID") not in described_ids:
            continue
        fields = (
            package.get("name"),
            package.get("packageFileName"),
            package.get("downloadLocation"),
            package.get("sourceInfo"),
        )
        if any(field_contains_digest(field, digest_ref, digest) for field in fields):
            return True
        refs = package.get("externalRefs")
        if isinstance(refs, list):
            for ref in refs:
                if isinstance(ref, dict) and field_contains_digest(ref.get("referenceLocator"), digest_ref, digest):
                    return True
    return False


def spdx_subject_contains_file_digest(data: object, file_name: str, digest: str) -> bool:
    if not isinstance(data, dict):
        return False
    described = data.get("documentDescribes")
    packages = data.get("packages")
    if not isinstance(described, list) or not isinstance(packages, list):
        return False
    described_ids = {item for item in described if isinstance(item, str)}
    if not described_ids:
        return False
    for package in packages:
        if not isinstance(package, dict) or package.get("SPDXID") not in described_ids:
            continue
        if package.get("name") != file_name and package.get("packageFileName") != file_name:
            continue
        checksums = package.get("checksums")
        if not isinstance(checksums, list):
            continue
        for checksum in checksums:
            if not isinstance(checksum, dict):
                continue
            if checksum.get("algorithm") == "SHA256" and checksum.get("checksumValue") == digest:
                return True
    return False


def bind_spdx_subject(spdx_path: Path, image_name: str, digest_ref: str) -> int:
    digest_match = IMAGE_DIGEST_REF.fullmatch(digest_ref)
    if digest_match is None:
        print(f"error: digest ref must match image@sha256:<64 hex>, got {digest_ref}", file=sys.stderr)
        return 1
    digest = digest_match.group(2)
    try:
        data = load_json(spdx_path)
        if not isinstance(data, dict):
            raise ValueError("SPDX document must be an object")
        packages = data.setdefault("packages", [])
        described = data.setdefault("documentDescribes", [])
        if not isinstance(packages, list) or not isinstance(described, list):
            raise ValueError("SPDX document packages and documentDescribes must be arrays")
        subject_id = f"SPDXRef-RegistryStack-{image_name}-digest-subject"
        packages[:] = [package for package in packages if not (isinstance(package, dict) and package.get("SPDXID") == subject_id)]
        packages.append(
            {
                "SPDXID": subject_id,
                "name": digest_ref,
                "downloadLocation": "NOASSERTION",
                "filesAnalyzed": False,
                "externalRefs": [
                    {
                        "referenceCategory": "PACKAGE-MANAGER",
                        "referenceType": "purl",
                        "referenceLocator": f"pkg:oci/{image_name}@{digest}",
                    }
                ],
            }
        )
        if subject_id not in described:
            described.append(subject_id)
        spdx_path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    print(f"bound SPDX subject {subject_id} to {digest_ref}")
    return 0


def spdx_id_component(value: str) -> str:
    return re.sub(r"[^A-Za-z0-9.-]+", "-", value).strip("-") or "asset"


def bind_spdx_file_subject(spdx_path: Path, file_name: str, digest: str) -> int:
    if Path(file_name).name != file_name or not file_name:
        print(f"error: file name must be a bare release asset name, got {file_name}", file=sys.stderr)
        return 1
    if SHA256_HEX.fullmatch(digest) is None:
        print(f"error: sha256 must be 64 lowercase hex characters, got {digest}", file=sys.stderr)
        return 1
    try:
        data = load_json(spdx_path)
        if not isinstance(data, dict):
            raise ValueError("SPDX document must be an object")
        packages = data.setdefault("packages", [])
        described = data.setdefault("documentDescribes", [])
        if not isinstance(packages, list) or not isinstance(described, list):
            raise ValueError("SPDX document packages and documentDescribes must be arrays")
        subject_id = f"SPDXRef-RegistryStack-{spdx_id_component(file_name)}-sha256-subject"
        packages[:] = [package for package in packages if not (isinstance(package, dict) and package.get("SPDXID") == subject_id)]
        packages.append(
            {
                "SPDXID": subject_id,
                "name": file_name,
                "packageFileName": file_name,
                "downloadLocation": "NOASSERTION",
                "filesAnalyzed": False,
                "checksums": [
                    {
                        "algorithm": "SHA256",
                        "checksumValue": digest,
                    }
                ],
            }
        )
        if subject_id not in described:
            described.append(subject_id)
        spdx_path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    print(f"bound SPDX subject {subject_id} to {file_name} sha256:{digest}")
    return 0


def grype_db_timestamp(report: object) -> str:
    for keys in (
        ("descriptor", "db", "built"),
        ("descriptor", "db", "checksum"),
        ("descriptor", "db", "schemaVersion"),
    ):
        value = nested(report, *keys)
        if value:
            return str(value)
    return "not-recorded"


def grype_version(report: object) -> str:
    value = nested(report, "descriptor", "version")
    return str(value) if value else "not-recorded"


def parse_sha256s(path: Path) -> dict[str, str]:
    checksums: dict[str, str] = {}
    if not path.exists():
        return checksums
    for line in path.read_text(encoding="utf-8").splitlines():
        parts = line.split()
        if len(parts) >= 2:
            checksums[parts[-1].lstrip("*")] = parts[0]
    return checksums


def verified_binary_sha256(path: Path, checksums: dict[str, str]) -> str:
    expected = checksums.get(path.name)
    if expected is None:
        raise ValueError(f"{path.name} is missing from SHA256SUMS")
    actual = sha256(path)
    if expected != actual:
        raise ValueError(f"{path.name} SHA256SUMS entry does not match file contents")
    return actual


def render_capsule(
    manifest_path: Path,
    tag: str,
    version: str,
    binary_dir: Path,
    binary_sbom_dir: Path,
    image_evidence_dir: Path,
    output_json: Path,
    output_markdown: Path,
    workflow_name: str,
    workflow_run_url: str,
    workflow_run_id: str,
    default_branch_protection: str,
    repo: Path,
    default_branch: str,
    require_registryctl_image_lock: bool = False,
) -> int:
    manifest = load_yaml(manifest_path)
    if not isinstance(manifest, dict):
        print("error: release manifest must be an object", file=sys.stderr)
        return 1
    if default_branch_protection not in {"verified", "unverified", "not-public"}:
        print("error: default branch protection must be verified, unverified, or not-public", file=sys.stderr)
        return 1

    try:
        checksums = parse_sha256s(binary_dir / "SHA256SUMS")
        binaries = []
        release_files = []
        expected_image_lock_name = f"registryctl-v{version}-image-lock.json"
        for path in sorted(binary_dir.iterdir()) if binary_dir.exists() else []:
            if not path.is_file() or path.name == "SHA256SUMS":
                continue
            if path.name.endswith("-image-lock.json") and path.name != expected_image_lock_name:
                raise ValueError(
                    f"unexpected registryctl image lock filename {path.name}; expected {expected_image_lock_name}"
                )
            file_sha256 = verified_binary_sha256(path, checksums)
            sbom = binary_sbom_dir / f"{path.name}.spdx.json"
            if not sbom.is_file():
                raise ValueError(f"{path.name} is missing a file SBOM")
            sbom_report = load_json(sbom)
            if not spdx_subject_contains_file_digest(sbom_report, path.name, file_sha256):
                raise ValueError(f"{path.name} SBOM subject does not contain sha256:{file_sha256}")
            file_evidence = {
                "name": path.name,
                "path": str(path),
                "sha256": file_sha256,
                "sbom": {
                    "asset_name": sbom.name,
                    "subject": path.name,
                    "format": "spdx-json",
                    "sha256": sha256(sbom),
                },
            }
            if path.name == expected_image_lock_name:
                file_evidence["kind"] = "registryctl-release-image-lock"
                release_files.append(file_evidence)
            else:
                binaries.append(file_evidence)

        if require_registryctl_image_lock and len(release_files) != 1:
            raise ValueError(
                f"capsule requires exactly one registryctl release image lock named {expected_image_lock_name}"
            )

        images = []
        for digest_path in sorted(image_evidence_dir.rglob("*.digest")):
            name = digest_path.stem
            digest_ref = digest_path.read_text(encoding="utf-8").strip()
            digest_match = IMAGE_DIGEST_REF.fullmatch(digest_ref)
            if digest_match is None:
                raise ValueError(f"{name} digest ref must match image@sha256:<64 hex>")
            digest = digest_match.group(2)
            sbom = find_image_evidence(image_evidence_dir, name, ".spdx.json")
            grype = find_image_evidence(image_evidence_dir, name, ".grype.json")
            if sbom is None:
                raise ValueError(f"{name} is missing an SBOM file")
            if grype is None:
                raise ValueError(f"{name} is missing a Grype report")
            sbom_report = load_json(sbom)
            if not spdx_subject_contains_digest(sbom_report, digest_ref, digest):
                raise ValueError(f"{name} SBOM subject does not contain digest {digest_ref}")
            grype_report = load_json(grype)
            subject = grype_subject(grype_report)
            if not subject:
                raise ValueError(f"{name} Grype report has no digest-bound subject")
            if subject not in {digest_ref, digest}:
                raise ValueError(f"{name} Grype subject {subject} does not match digest ref {digest_ref}")
            summary = severity_summary(grype_report)
            image = {
                "name": name,
                "digest_ref": digest_ref,
                "digest": digest,
                "tag": tag,
                "tag_ref": f"{digest_ref.rsplit('@', 1)[0]}:{tag}",
                "sbom": {
                    "asset_name": sbom.name,
                    "subject": digest_ref,
                    "format": "spdx-json",
                    "sha256": sha256(sbom),
                },
                "vulnerability_scan": {
                    "asset_name": grype.name,
                    "subject": digest_ref,
                    "scanner": "grype",
                    "scanner_version": grype_version(grype_report),
                    "vulnerability_db_timestamp": grype_db_timestamp(grype_report),
                    "severity_summary": summary,
                    "release_decision_status": release_decision_status(summary),
                    "sha256": sha256(grype),
                },
            }
            images.append(image)

        errors, source = source_lineage(manifest, tag, repo, default_branch)
        if errors:
            raise ValueError("; ".join(errors))
        for release_file in release_files:
            validate_registryctl_image_lock_document(
                load_json(Path(release_file["path"])),
                version=version,
                release_tag=tag,
                manifest_source_ref=str(manifest["stack"]["source_ref"]),
                tag_target=source["source_commit"],
            )
        evidence = {
            "release_tag": tag,
            "version": version,
            "repository": manifest["stack"]["source_repo"],
            "source": source,
            "workflow": {
                "name": workflow_name,
                "run_url": workflow_run_url,
                "run_id": workflow_run_id,
            },
            "manifest": {
                "path": str(manifest_path),
                "sha256": sha256(manifest_path),
            },
            "default_branch_protection": {"status": default_branch_protection},
            "external_pinned_inputs": manifest.get("external", {}),
            "binaries": binaries,
            "release_files": release_files,
            "images": images,
            "warnings": manifest.get("warnings", []),
            "hosted_publication_status": hosted_publication_status(manifest),
        }
        if not binaries:
            raise ValueError("capsule requires at least one binary artifact")
        if not images:
            raise ValueError("capsule requires at least one image artifact")
    except (KeyError, OSError, ValueError, json.JSONDecodeError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1

    output_json.parent.mkdir(parents=True, exist_ok=True)
    output_markdown.parent.mkdir(parents=True, exist_ok=True)
    output_json.write_text(json.dumps(evidence, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    output_markdown.write_text(capsule_markdown(evidence), encoding="utf-8")
    print(f"rendered release capsule {output_json} and {output_markdown}")
    return 0


def capsule_markdown(evidence: dict) -> str:
    lines = [
        f"# RegistryStack {evidence['release_tag']} Release Trust Capsule",
        "",
        f"- Version: `{evidence['version']}`",
        f"- Source repository: `{evidence['repository']}`",
        f"- Source tag: `{evidence['source']['source_tag']}`",
        f"- Source ref: `{evidence['source']['source_ref']}`",
        f"- Workflow: {evidence['workflow']['name']} run `{evidence['workflow']['run_id']}` ({evidence['workflow']['run_url']})",
        f"- Manifest: `{evidence['manifest']['path']}` (`{evidence['manifest']['sha256']}`)",
        f"- Default branch protection: `{evidence['default_branch_protection']['status']}`",
        f"- Hosted/public announcement status: `{evidence['hosted_publication_status']}`",
        "",
        "## Binaries",
        "",
    ]
    for binary in evidence["binaries"]:
        lines.append(
            f"- `{binary['name']}` sha256 `{binary['sha256']}`; "
            f"SBOM `{binary['sbom']['asset_name']}`"
        )
    release_files = evidence.get("release_files") or []
    if release_files:
        lines.extend(["", "## Release files", ""])
        for release_file in release_files:
            lines.append(
                f"- `{release_file['name']}` ({release_file['kind']}) sha256 "
                f"`{release_file['sha256']}`; SBOM `{release_file['sbom']['asset_name']}`"
            )
    lines.extend(["", "## Images", ""])
    for image in evidence["images"]:
        scan = image["vulnerability_scan"]
        lines.append(f"- `{image['name']}` tag `{image['tag_ref']}` digest `{image['digest_ref']}`; SBOM `{image['sbom']['asset_name']}`; Grype `{scan['asset_name']}`")
    lines.extend(["", "## Caveats", ""])
    warnings = evidence.get("warnings") or []
    if warnings:
        for warning in warnings:
            lines.append(f"- `{warning.get('code', 'warning')}`: {warning.get('detail', '')}")
    else:
        lines.append("- No release warnings recorded.")
    return "\n".join(lines) + "\n"


def hosted_publication_status(manifest: dict) -> str:
    warnings = manifest.get("warnings", []) if isinstance(manifest, dict) else []
    for warning in warnings:
        if isinstance(warning, dict) and warning.get("code") == "hosted-publication-held":
            return "held"
    return "not-recorded"


def audit(import_map_path: Path) -> int:
    data = load_yaml(import_map_path)
    errors: list[str] = []
    imports = data.get("imports", []) if isinstance(data, dict) else []
    if not imports:
        errors.append("import map has no imports")
    for entry in imports:
        old_repo = entry.get("old_repo", "<unknown>")
        if entry.get("old_commit_count") != entry.get("imported_commit_count"):
            errors.append(f"{old_repo}: imported commit count differs")
        if entry.get("old_tag_count") != entry.get("imported_tag_count"):
            errors.append(f"{old_repo}: imported tag count differs")
        if not str(entry.get("imported_ref", "")).strip():
            errors.append(f"{old_repo}: imported_ref is required")
        tag_prefix = str(entry.get("legacy_tag_prefix", ""))
        if tag_prefix:
            result = subprocess.run(
                ["git", "tag", "--list", f"{tag_prefix}*"],
                cwd=ROOT,
                text=True,
                capture_output=True,
                check=False,
            )
            count = len([line for line in result.stdout.splitlines() if line.strip()])
            if count != entry.get("imported_tag_count"):
                errors.append(f"{old_repo}: expected {entry.get('imported_tag_count')} tags under {tag_prefix}, found {count}")
    if (ROOT / "imports").exists():
        errors.append("staging imports/ directory must not exist after layout migration")

    if errors:
        for error in errors:
            print(f"error: {error}", file=sys.stderr)
        return 1
    print(f"audited {len(imports)} imports from {import_map_path}")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="registry-release")
    subparsers = parser.add_subparsers(dest="command", required=True)
    validate_parser = subparsers.add_parser("validate")
    validate_parser.add_argument("manifest", type=Path)
    docsets_parser = subparsers.add_parser("validate-docsets")
    docsets_parser.add_argument(
        "--manifest-dir", type=Path, default=RELEASE_MANIFEST_DIR
    )
    docsets_parser.add_argument("--docsets", type=Path, default=DOCSETS_PATH)
    source_parser = subparsers.add_parser("validate-source")
    source_parser.add_argument("manifest", type=Path)
    source_parser.add_argument("--tag", required=True)
    source_parser.add_argument("--repo", type=Path, default=ROOT)
    source_parser.add_argument("--default-branch", default="origin/main")
    audit_parser = subparsers.add_parser("audit")
    audit_parser.add_argument("import_map", type=Path)
    stage_parser = subparsers.add_parser("stage-capsule-backfill-assets")
    stage_parser.add_argument("asset_dir", type=Path)
    stage_parser.add_argument("--tag", required=True)
    stage_parser.add_argument("--binary-dir", type=Path, required=True)
    stage_parser.add_argument("--image-evidence-dir", type=Path, required=True)
    bind_spdx_parser = subparsers.add_parser("bind-spdx-subject")
    bind_spdx_parser.add_argument("spdx", type=Path)
    bind_spdx_parser.add_argument("--image-name", required=True)
    bind_spdx_parser.add_argument("--digest-ref", required=True)
    bind_file_spdx_parser = subparsers.add_parser("bind-spdx-file-subject")
    bind_file_spdx_parser.add_argument("spdx", type=Path)
    bind_file_spdx_parser.add_argument("--file-name", required=True)
    bind_file_spdx_parser.add_argument("--sha256", required=True)
    image_lock_parser = subparsers.add_parser("render-registryctl-image-lock")
    image_lock_parser.add_argument("manifest", type=Path)
    image_lock_parser.add_argument("--relay-digest", type=Path, required=True)
    image_lock_parser.add_argument("--notary-digest", type=Path, required=True)
    image_lock_parser.add_argument("--tag-target", required=True)
    image_lock_parser.add_argument("--output", type=Path, required=True)
    image_lock_version_parser = subparsers.add_parser(
        "verify-registryctl-image-lock-release-version"
    )
    image_lock_version_parser.add_argument("--version", required=True)
    binary_version_parser = subparsers.add_parser("verify-registryctl-binary-version")
    binary_version_parser.add_argument("binary", type=Path)
    binary_version_parser.add_argument("--version", required=True)
    capsule_parser = subparsers.add_parser("render-capsule")
    capsule_parser.add_argument("manifest", type=Path)
    capsule_parser.add_argument("--tag", required=True)
    capsule_parser.add_argument("--version", required=True)
    capsule_parser.add_argument("--binary-dir", type=Path, required=True)
    capsule_parser.add_argument("--binary-sbom-dir", type=Path, required=True)
    capsule_parser.add_argument("--image-evidence-dir", type=Path, required=True)
    capsule_parser.add_argument("--output-json", type=Path, required=True)
    capsule_parser.add_argument("--output-markdown", type=Path, required=True)
    capsule_parser.add_argument("--workflow-name", default="RegistryStack Release")
    capsule_parser.add_argument("--workflow-run-url", required=True)
    capsule_parser.add_argument("--workflow-run-id", default="not-recorded")
    capsule_parser.add_argument("--default-branch-protection", default="unverified")
    capsule_parser.add_argument("--repo", type=Path, default=ROOT)
    capsule_parser.add_argument("--default-branch", default="origin/main")
    capsule_parser.add_argument("--require-registryctl-image-lock", action="store_true")
    args = parser.parse_args()

    if args.command == "validate":
        return validate(args.manifest)
    if args.command == "validate-docsets":
        return validate_docsets(args.manifest_dir, args.docsets)
    if args.command == "validate-source":
        return validate_source(args.manifest, args.tag, args.repo, args.default_branch)
    if args.command == "audit":
        return audit(args.import_map)
    if args.command == "stage-capsule-backfill-assets":
        return stage_capsule_backfill_assets(args.asset_dir, args.tag, args.binary_dir, args.image_evidence_dir)
    if args.command == "bind-spdx-subject":
        return bind_spdx_subject(args.spdx, args.image_name, args.digest_ref)
    if args.command == "bind-spdx-file-subject":
        return bind_spdx_file_subject(args.spdx, args.file_name, args.sha256)
    if args.command == "render-registryctl-image-lock":
        return render_registryctl_image_lock(
            args.manifest,
            args.relay_digest,
            args.notary_digest,
            args.tag_target,
            args.output,
        )
    if args.command == "verify-registryctl-image-lock-release-version":
        return verify_registryctl_image_lock_release_version(args.version)
    if args.command == "verify-registryctl-binary-version":
        return verify_registryctl_binary_version(args.binary, args.version)
    if args.command == "render-capsule":
        return render_capsule(
            args.manifest,
            args.tag,
            args.version,
            args.binary_dir,
            args.binary_sbom_dir,
            args.image_evidence_dir,
            args.output_json,
            args.output_markdown,
            args.workflow_name,
            args.workflow_run_url,
            args.workflow_run_id,
            args.default_branch_protection,
            args.repo,
            args.default_branch,
            args.require_registryctl_image_lock,
        )
    raise AssertionError(args.command)


if __name__ == "__main__":
    raise SystemExit(main())
