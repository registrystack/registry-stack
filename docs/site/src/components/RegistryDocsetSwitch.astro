---
import docsetsManifest from '../data/generated/docsets.json';
import { pathForDocset } from '../lib/docset-path.mjs';

const activeDocsetId = process.env.DOCS_DOCSET || docsetsManifest.current;
const activeDocset =
  docsetsManifest.docsets.find((docset) => docset.id === activeDocsetId) ??
  docsetsManifest.docsets.find((docset) => docset.id === docsetsManifest.current);

const activePath = activeDocset?.path ?? '/';
---

<label class="registry-version-switch">
  <span>Version</span>
  <select
    aria-label="Docs version"
    onchange="if (this.value) window.location.assign(this.value)"
    oninput="if (this.value) window.location.assign(this.value)"
  >
    {docsetsManifest.docsets.map((docset) => (
      <option
        value={pathForDocset(Astro.url.pathname, activePath, docset.path, import.meta.env.BASE_URL)}
        selected={docset.id === activeDocset?.id}
      >
        {docset.label}
      </option>
    ))}
  </select>
</label>
