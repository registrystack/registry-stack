---
import projects from '../data/generated/projects.json';
---

<div class="project-map">
  {projects.map((project) => (
    <section class="project-card" id={project.id}>
      <header class="card-header">
        <h3>{project.name}</h3>
        <code class="card-id">{project.id}</code>
      </header>

      {project.role && (
        <div class="card-body">
          <p>{project.role}</p>
        </div>
      )}

      <div class="project-ownership">
        <div class="ownership-col">
          <h4 class="ownership-label">Owns</h4>
          <ul>
            {project.owns.map((item: string) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="ownership-col">
          <h4 class="ownership-label">Does not own</h4>
          <ul>
            {project.does_not_own.map((item: string) => <li>{item}</li>)}
          </ul>
        </div>
      </div>

      {project.source_docs && project.source_docs.length > 0 && (
        <footer class="card-footer">
          <span class="footer-label">Source docs</span>
          <ul class="link-list">
            {project.source_docs.map((doc: { url: string; label: string }) => (
              <li><a href={doc.url}>{doc.label}</a></li>
            ))}
          </ul>
        </footer>
      )}
    </section>
  ))}
</div>
<p class="source-note">Update via <code>projects.yaml</code>. Generated from <code>src/data/projects.yaml</code>.</p>
