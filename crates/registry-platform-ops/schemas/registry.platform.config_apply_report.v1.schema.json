{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://id.registrystack.org/schemas/registry-platform/registry.platform.config_apply_report.v1.schema.json",
  "title": "Registry Platform Config Apply Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "attempt_id",
    "component",
    "stream_id",
    "source",
    "result",
    "restart_required",
    "change_classes",
    "affected_components",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema": {
      "const": "registry.platform.config_apply_report.v1"
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "component": {
      "type": "string",
      "enum": ["registry-relay", "registry-notary"]
    },
    "stream_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": ["local_file", "signed_bundle_file", "signed_bundle_endpoint", "unknown"]
    },
    "bundle_id": {
      "type": ["string", "null"]
    },
    "bundle_sequence": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "previous_config_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "config_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "result": {
      "type": "string",
      "enum": [
        "verified",
        "applied",
        "rejected_signature",
        "rejected_threshold",
        "rejected_freshness",
        "rejected_rollback",
        "rejected_restart_required",
        "rejected_readiness",
        "rejected_break_glass",
        "rejected_local_approval",
        "internal_error"
      ]
    },
    "restart_required": {
      "type": "boolean"
    },
    "change_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "affected_components": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
