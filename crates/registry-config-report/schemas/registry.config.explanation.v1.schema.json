{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry-platform.example/schemas/registry.config.explanation.v1.schema.json",
  "title": "Registry Product Config Explanation v1",
  "type": "object",
  "required": [
    "schema_version",
    "product",
    "config_schema_version",
    "source",
    "context_constraints",
    "resolved_config",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "registry.config.explanation.v1"
    },
    "product": {
      "$ref": "#/$defs/non_empty_string"
    },
    "config_schema_version": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "required_env": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/required_env"
      },
      "default": []
    },
    "defaults_applied": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/config_default"
      },
      "default": []
    },
    "optional_sections_absent": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/optional_section"
      },
      "default": []
    },
    "live_apply": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/live_apply_component"
      },
      "default": []
    },
    "context_constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context_constraint"
      },
      "default": []
    },
    "resolved_config": {
      "type": ["object", "array", "string", "number", "boolean", "null"]
    },
    "hashes": {
      "$ref": "#/$defs/hashes"
    },
    "generated_at": {
      "$ref": "#/$defs/rfc3339_timestamp"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "rfc3339_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "sha256_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "classification": {
      "enum": ["public", "secret", "topology_sensitive", "internal_only"]
    },
    "env_status": {
      "enum": ["present", "missing", "not_checked"]
    },
    "source": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "local_file",
            "generated_file",
            "signed_bundle_file",
            "signed_bundle_endpoint",
            "unknown"
          ]
        },
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "uri": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "required_env": {
      "type": "object",
      "required": ["name", "classification", "status"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "classification": {
          "$ref": "#/$defs/classification"
        },
        "status": {
          "$ref": "#/$defs/env_status"
        }
      }
    },
    "config_default": {
      "type": "object",
      "required": ["path", "value"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "value": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        }
      }
    },
    "optional_section": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reason": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "live_apply_component": {
      "type": "object",
      "required": ["path", "class"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "class": {
          "enum": [
            "hot_swappable",
            "restart_required",
            "unsupported_live_apply"
          ]
        }
      }
    },
    "trusted_value_source": {
      "enum": [
        "static_credential_authorization_details",
        "oidc_authorization_details",
        "federation_authorization_details",
        "principal_scope",
        "route_default",
        "source_observation_timestamp",
        "adapter_injected_observation_timestamp",
        "not_configured",
        "unknown"
      ]
    },
    "context_constraint": {
      "type": "object",
      "required": [
        "container_path",
        "product",
        "platform_contract",
        "hash_material_contract",
        "legal_basis",
        "consent",
        "jurisdiction",
        "assurance",
        "source_freshness",
        "product_owned_adjacent_controls"
      ],
      "additionalProperties": false,
      "properties": {
        "container_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "product": {
          "enum": ["registry-relay", "registry-notary"]
        },
        "platform_contract": {
          "$ref": "#/$defs/non_empty_string"
        },
        "hash_material_contract": {
          "$ref": "#/$defs/non_empty_string"
        },
        "legal_basis": {
          "type": "object",
          "required": [
            "required",
            "approved_value_check",
            "allowed_ref_count",
            "trusted_value_source"
          ],
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean"
            },
            "approved_value_check": {
              "type": "boolean"
            },
            "allowed_ref_count": {
              "type": "integer",
              "minimum": 0
            },
            "trusted_value_source": {
              "$ref": "#/$defs/trusted_value_source"
            }
          }
        },
        "consent": {
          "type": "object",
          "required": [
            "required",
            "approved_value_check",
            "allowed_ref_count",
            "trusted_value_source"
          ],
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean"
            },
            "approved_value_check": {
              "type": "boolean"
            },
            "allowed_ref_count": {
              "type": "integer",
              "minimum": 0
            },
            "trusted_value_source": {
              "$ref": "#/$defs/trusted_value_source"
            }
          }
        },
        "jurisdiction": {
          "type": "object",
          "required": ["permitted_count", "trusted_value_source"],
          "additionalProperties": false,
          "properties": {
            "permitted_count": {
              "type": "integer",
              "minimum": 0
            },
            "trusted_value_source": {
              "$ref": "#/$defs/trusted_value_source"
            }
          }
        },
        "assurance": {
          "type": "object",
          "required": [
            "allowed_count",
            "minimum",
            "trusted_value_source",
            "authn_derived"
          ],
          "additionalProperties": false,
          "properties": {
            "allowed_count": {
              "type": "integer",
              "minimum": 0
            },
            "minimum": {
              "type": ["string", "null"]
            },
            "trusted_value_source": {
              "$ref": "#/$defs/trusted_value_source"
            },
            "authn_derived": {
              "type": "boolean"
            }
          }
        },
        "source_freshness": {
          "type": "object",
          "required": [
            "max_age_seconds",
            "observation_field",
            "observation_timestamp_source",
            "observation_contract_proven"
          ],
          "additionalProperties": false,
          "properties": {
            "max_age_seconds": {
              "type": ["integer", "null"],
              "minimum": 1
            },
            "observation_field": {
              "type": ["string", "null"]
            },
            "observation_timestamp_source": {
              "$ref": "#/$defs/trusted_value_source"
            },
            "observation_contract_proven": {
              "type": "boolean"
            }
          }
        },
        "product_owned_adjacent_controls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "internal_config_hash": {
          "$ref": "#/$defs/sha256_hash"
        },
        "posture_safe_config_hash": {
          "$ref": "#/$defs/sha256_hash"
        }
      }
    }
  }
}
