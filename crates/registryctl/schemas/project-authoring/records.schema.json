{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registrystack.example/schemas/project-authoring/records.v1.json",
  "title": "Registry Stack governed records definition v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "primary_key", "fields", "api"],
  "properties": {
    "version": { "const": 1 },
    "id": { "type": "string", "maxLength": 45, "pattern": "^[a-z][a-z0-9_]*$" },
    "title": { "$ref": "#/$defs/text" },
    "description": { "$ref": "#/$defs/text" },
    "owner": { "$ref": "#/$defs/text" },
    "sensitivity": { "enum": ["public", "internal", "personal", "confidential", "secret"] },
    "access_rights": { "enum": ["public", "restricted", "non_public"] },
    "update_frequency": { "enum": ["continuous", "daily", "weekly", "termly", "monthly", "quarterly", "annual", "irregular", "as_needed", "unknown"] },
    "conforms_to": { "type": "array", "maxItems": 32, "uniqueItems": true, "items": { "$ref": "#/$defs/text" } },
    "primary_key": { "$ref": "#/$defs/stableId" },
    "fields": {
      "type": "object", "minProperties": 1, "maxProperties": 256,
      "propertyNames": { "$ref": "#/$defs/stableId" },
      "additionalProperties": { "$ref": "#/$defs/field" }
    },
    "api": { "$ref": "#/$defs/api" }
  },
  "$defs": {
    "stableId": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,95}$" },
    "text": { "type": "string", "minLength": 1, "maxLength": 2048 },
    "scope": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[^,\\s\\u0000-\\u001F\\u007F]+$" },
    "field": {
      "type": "object", "additionalProperties": false, "required": ["type"],
      "properties": {
        "type": { "enum": ["string", "number", "integer", "boolean", "date", "timestamp"] },
        "nullable": { "type": "boolean" }, "sensitive": { "type": "boolean" },
        "concept_uri": { "$ref": "#/$defs/text" }, "codelist": { "$ref": "#/$defs/text" },
        "unit": { "$ref": "#/$defs/text" }, "language": { "$ref": "#/$defs/text" }
      }
    },
    "api": {
      "type": "object", "additionalProperties": false,
      "required": ["scopes", "pagination", "standards"],
      "properties": {
        "scopes": { "$ref": "#/$defs/scopes" },
        "purposes": { "type": "array", "maxItems": 32, "uniqueItems": true, "items": { "$ref": "#/$defs/scope" } },
        "pagination": { "$ref": "#/$defs/pagination" },
        "filters": { "type": "object", "maxProperties": 256, "propertyNames": { "$ref": "#/$defs/stableId" }, "additionalProperties": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["eq", "in", "gte", "lte", "between"] } } },
        "required_principal_filters": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } },
        "relationships": { "type": "object", "maxProperties": 64, "propertyNames": { "$ref": "#/$defs/stableId" }, "additionalProperties": { "$ref": "#/$defs/relationship" } },
        "aggregates": { "type": "object", "maxProperties": 64, "propertyNames": { "$ref": "#/$defs/stableId" }, "additionalProperties": { "$ref": "#/$defs/aggregate" } },
        "standards": { "$ref": "#/$defs/standards" }
      }
    },
    "scopes": {
      "type": "object", "additionalProperties": false, "required": ["metadata", "rows"],
      "properties": { "metadata": { "$ref": "#/$defs/scope" }, "rows": { "$ref": "#/$defs/scope" }, "aggregate": { "$ref": "#/$defs/scope" }, "evidence_verification": { "$ref": "#/$defs/scope" } }
    },
    "pagination": {
      "type": "object", "additionalProperties": false, "required": ["default_limit", "max_limit"],
      "properties": { "default_limit": { "type": "integer", "minimum": 1, "maximum": 10000 }, "max_limit": { "type": "integer", "minimum": 1, "maximum": 10000 } }
    },
    "relationship": {
      "type": "object", "additionalProperties": false, "required": ["kind", "target", "foreign_key"],
      "properties": { "kind": { "enum": ["belongs_to", "has_many", "has_one"] }, "target": { "$ref": "#/$defs/stableId" }, "foreign_key": { "$ref": "#/$defs/stableId" }, "concept_uri": { "$ref": "#/$defs/text" } }
    },
    "aggregate": {
      "type": "object", "additionalProperties": false, "required": ["description", "disclosure_control"],
      "properties": {
        "title": { "$ref": "#/$defs/text" }, "description": { "$ref": "#/$defs/text" },
        "default_group_by": { "$ref": "#/$defs/fieldList" },
        "dimensions": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/dimension" } },
        "indicators": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/indicator" } },
        "allowed_filters": { "type": "object", "maxProperties": 256, "propertyNames": { "$ref": "#/$defs/stableId" }, "additionalProperties": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["eq", "in", "gte", "lte", "between"] } } },
        "required_principal_filters": { "$ref": "#/$defs/fieldList" },
        "temporal_field": { "$ref": "#/$defs/stableId" },
        "access": { "$ref": "#/$defs/aggregateAccess" },
        "spatial": { "$ref": "#/$defs/aggregateSpatial" },
        "joins": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } },
        "group_by": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } },
        "measures": { "type": "array", "minItems": 1, "maxItems": 32, "items": { "$ref": "#/$defs/measure" } },
        "disclosure_control": { "$ref": "#/$defs/disclosure" }
      },
      "anyOf": [{ "required": ["measures"] }, { "required": ["indicators"] }]
    },
    "fieldList": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/stableId" } },
    "dimension": { "type": "object", "additionalProperties": false, "required": ["id", "label", "field"], "properties": { "id": { "$ref": "#/$defs/stableId" }, "label": { "$ref": "#/$defs/text" }, "field": { "$ref": "#/$defs/stableId" }, "codelist": { "$ref": "#/$defs/text" } } },
    "indicator": { "type": "object", "additionalProperties": false, "required": ["id", "label", "function", "column", "unit_measure"], "properties": { "id": { "$ref": "#/$defs/stableId" }, "label": { "$ref": "#/$defs/text" }, "function": { "enum": ["count", "sum", "avg", "min", "max", "median", "count_distinct", "stddev"] }, "column": { "$ref": "#/$defs/stableId" }, "unit_measure": { "$ref": "#/$defs/text" }, "unit_mult": { "type": "integer" }, "decimals": { "type": "integer", "minimum": 0 }, "frequency": { "$ref": "#/$defs/text" }, "definition_uri": { "$ref": "#/$defs/text" } } },
    "aggregateAccess": { "type": "object", "additionalProperties": false, "properties": { "metadata_scope": { "$ref": "#/$defs/scope" }, "aggregate_scope": { "$ref": "#/$defs/scope" }, "aggregate_only_execution": { "type": "boolean" } } },
    "aggregateSpatial": { "type": "object", "additionalProperties": false, "required": ["mode", "dimension", "geometry_entity", "geometry_id_field", "geometry_field"], "properties": { "mode": { "const": "admin_area" }, "collection_id": { "$ref": "#/$defs/stableId" }, "dimension": { "$ref": "#/$defs/stableId" }, "geometry_entity": { "$ref": "#/$defs/stableId" }, "geometry_id_field": { "$ref": "#/$defs/stableId" }, "geometry_field": { "$ref": "#/$defs/stableId" }, "bbox_fields": { "$ref": "#/$defs/bbox" }, "max_geometry_vertices": { "type": "integer", "minimum": 1 } } },
    "measure": {
      "type": "object", "additionalProperties": false, "required": ["name", "function", "column"],
      "properties": { "name": { "$ref": "#/$defs/stableId" }, "function": { "enum": ["count", "sum", "avg", "min", "max", "median", "count_distinct", "stddev"] }, "column": { "$ref": "#/$defs/stableId" } }
    },
    "disclosure": {
      "type": "object", "additionalProperties": false,
      "properties": { "min_group_size": { "type": "integer", "minimum": 1 }, "suppression": { "enum": ["omit", "mask", "null"] } }
    },
    "standards": {
      "type": "object", "additionalProperties": false, "required": ["ogc_features", "sp_dci"],
      "properties": { "ogc_features": { "oneOf": [{ "const": false }, { "$ref": "#/$defs/spatial" }] }, "sp_dci": { "oneOf": [{ "const": false }, { "$ref": "#/$defs/spdci" }] } }
    },
    "spatial": {
      "type": "object", "additionalProperties": false, "required": ["geometry"],
      "properties": {
        "collection_id": { "$ref": "#/$defs/stableId" }, "title": { "$ref": "#/$defs/text" }, "description": { "$ref": "#/$defs/text" },
        "geometry": { "$ref": "#/$defs/geometry" }, "bbox_fields": { "$ref": "#/$defs/bbox" }, "datetime_field": { "$ref": "#/$defs/stableId" },
        "max_bbox_degrees": { "type": "number", "exclusiveMinimum": 0 }, "max_geometry_vertices": { "type": "integer", "minimum": 1 }
      }
    },
    "geometry": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind", "longitude_field", "latitude_field", "crs"], "properties": { "kind": { "const": "point" }, "longitude_field": { "$ref": "#/$defs/stableId" }, "latitude_field": { "$ref": "#/$defs/stableId" }, "crs": { "$ref": "#/$defs/text" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind", "field", "crs"], "properties": { "kind": { "enum": ["geojson", "wkt", "wkb"] }, "field": { "$ref": "#/$defs/stableId" }, "crs": { "$ref": "#/$defs/text" } } }
      ]
    },
    "bbox": { "type": "object", "additionalProperties": false, "required": ["min_x", "min_y", "max_x", "max_y"], "properties": { "min_x": { "$ref": "#/$defs/stableId" }, "min_y": { "$ref": "#/$defs/stableId" }, "max_x": { "$ref": "#/$defs/stableId" }, "max_y": { "$ref": "#/$defs/stableId" } } },
    "spdci": {
      "type": "object", "additionalProperties": false, "required": ["registry", "registry_type", "record_type", "identifiers", "expression_fields"],
      "properties": {
        "registry": { "$ref": "#/$defs/stableId" }, "registry_type": { "$ref": "#/$defs/text" }, "record_type": { "$ref": "#/$defs/text" },
        "identifiers": { "type": "object", "minProperties": 1, "additionalProperties": { "$ref": "#/$defs/stableId" } },
        "expression_fields": { "type": "object", "minProperties": 1, "additionalProperties": { "$ref": "#/$defs/stableId" } },
        "response_fields": { "type": "object", "additionalProperties": { "$ref": "#/$defs/stableId" } }
      }
    }
  }
}
