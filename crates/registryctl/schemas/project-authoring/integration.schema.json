{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registrystack.example/schemas/project-authoring/integration.v1.json",
  "title": "Registry Stack project integration v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "revision", "input", "capability", "outputs"],
  "properties": {
    "version": { "const": 1 },
    "id": { "$ref": "#/$defs/stableId" },
    "revision": { "type": "integer", "minimum": 1 },
    "source": { "$ref": "#/$defs/source" },
    "input": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 16,
      "propertyNames": { "$ref": "#/$defs/inputName" },
      "additionalProperties": { "$ref": "#/$defs/input" }
    },
    "capability": { "$ref": "#/$defs/capability" },
    "outputs": {
      "oneOf": [
        {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 64,
          "propertyNames": {
            "allOf": [
              { "$ref": "#/$defs/inputName" },
              { "not": { "enum": ["matched", "outcome"] } }
            ]
          },
          "additionalProperties": { "$ref": "#/$defs/output" }
        },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/inputName" }
        }
      ]
    },
    "limits": { "$ref": "#/$defs/limits" }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]{0,95}$"
    },
    "inputName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?/)(?!.*//).+$"
    },
    "byteSize": {
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "pattern": "^[1-9][0-9]*(?:KiB|MiB)$" }
      ]
    },
    "scalarType": {
      "oneOf": [
        { "enum": ["string", "boolean", "integer"] },
        {
          "type": "array",
          "prefixItems": [
            { "enum": ["string", "boolean", "integer"] },
            { "const": "null" }
          ],
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        }
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "type"],
      "properties": {
        "role": { "enum": ["selector", "parameter"] },
        "type": { "$ref": "#/$defs/scalarType" },
        "format": { "const": "date" },
        "maxLength": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "minLength": { "type": "integer", "minimum": 0, "maximum": 16384 },
        "pattern": { "type": "string", "minLength": 1, "maxLength": 16384 },
        "minimum": { "type": "integer" },
        "maximum": { "type": "integer" },
        "canonicalization": { "enum": ["identity", "ascii_lowercase"] }
      }
    },
    "versions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tested": { "$ref": "#/$defs/versionList" },
        "unverified": { "$ref": "#/$defs/versionList" }
      },
      "anyOf": [
        { "required": ["tested"], "properties": { "tested": { "minItems": 1 } } },
        { "required": ["unverified"], "properties": { "unverified": { "minItems": 1 } } }
      ]
    },
    "versionList": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "credential": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "enum": ["none", "basic", "static_bearer"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "name", "max_value_bytes"],
          "properties": {
            "type": { "const": "api_key_header" },
            "name": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$" },
            "max_value_bytes": { "type": "integer", "minimum": 1, "maximum": 4096 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "name", "max_value_bytes"],
          "properties": {
            "type": { "const": "api_key_query" },
            "name": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9._:~-]{0,95}$" },
            "max_value_bytes": { "type": "integer", "minimum": 1, "maximum": 4096 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "request", "response_profile"],
          "properties": {
            "type": { "const": "oauth2_client_credentials" },
            "request": { "enum": ["form", "json"] },
            "response_profile": { "const": "oauth2_bearer" },
            "scope": { "type": "string", "minLength": 1, "maxLength": 1024 },
            "audience": { "type": "string", "minLength": 1, "maxLength": 2048 },
            "refresh_skew": { "type": "string", "pattern": "^[1-9][0-9]*(?:ms|s)$" }
          }
        }
      ]
    },
    "allowRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path"],
      "properties": {
        "method": { "enum": ["GET", "POST"] },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^/[^?#]*$"
        },
        "semantics": { "const": "read_only" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["auth"],
      "properties": {
        "product": { "type": "string", "minLength": 1, "maxLength": 256 },
        "versions": { "$ref": "#/$defs/versions" },
        "auth": { "$ref": "#/$defs/credential" },
        "allow": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/allowRule" }
        },
        "request_headers": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9-]{0,63}$" }
        },
        "response_headers": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9-]{0,63}$" }
        },
        "response": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "format": { "enum": ["json", "text"] },
            "max_bytes": { "$ref": "#/$defs/byteSize" }
          }
        },
        "protocol": { "$ref": "#/$defs/protocol" }
      }
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signed_dci": {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile", "path", "jwks_profile", "sender", "receiver", "registry_type", "record_type", "locale", "selectors"],
          "properties": {
            "profile": { "const": "dci-search-v1" },
            "path": { "type": "string", "pattern": "^/[^?#]*$" },
            "jwks_profile": { "const": "rsa-signing-jwks-v1" },
            "sender": { "type": "string", "minLength": 1, "maxLength": 256 },
            "receiver": { "type": "string", "minLength": 1, "maxLength": 256 },
            "registry_type": { "type": "string", "minLength": 1, "maxLength": 128 },
            "record_type": { "type": "string", "minLength": 1, "maxLength": 128 },
            "locale": { "type": "string", "pattern": "^[A-Za-z]{2,8}(?:-[A-Za-z0-9]{1,8})*$" },
            "selectors": {
              "type": "object", "minProperties": 1, "maxProperties": 8,
              "propertyNames": { "$ref": "#/$defs/inputName" },
              "additionalProperties": {
                "type": "object", "additionalProperties": false, "required": ["field", "response_pointer"],
                "properties": {
                  "field": { "type": "string", "minLength": 1, "maxLength": 160 },
                  "response_pointer": { "type": "string", "pattern": "^/(?:[^/~]|~[01])+(?:/(?:[^/~]|~[01])+)*$" }
                }
              }
            }
          }
        }
      },
      "minProperties": 1
    },
    "inputReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input"],
      "properties": { "input": { "$ref": "#/$defs/inputName" } }
    },
    "inputOrLiteral": {
      "oneOf": [
        { "$ref": "#/$defs/inputReference" },
        { "type": ["string", "boolean", "integer"] }
      ]
    },
    "httpRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path"],
      "properties": {
        "method": { "enum": ["GET", "POST"] },
        "path": { "type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^/[^?#]*$" },
        "semantics": { "const": "read_only" },
        "query": { "type": "object", "maxProperties": 64, "additionalProperties": { "$ref": "#/$defs/inputOrLiteral" } },
        "headers": { "type": "object", "maxProperties": 32, "additionalProperties": { "$ref": "#/$defs/inputOrLiteral" } },
        "body": true
      }
    },
    "httpResponse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "no_match": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 100, "maximum": 599 }
        },
        "ambiguous": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "integer", "minimum": 100, "maximum": 599 }
        },
        "shape": {
          "oneOf": [
            { "const": "singleton" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["records", "cardinality"],
              "properties": {
                "records": { "type": "string", "pattern": "^/(?:[^/~]|~[01])+(?:/(?:[^/~]|~[01])+)*$" },
                "cardinality": { "const": "probe_two" }
              }
            }
          ]
        }
      }
    },
    "capability": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["http"],
          "properties": {
            "http": {
              "type": "object",
              "additionalProperties": false,
              "required": ["request"],
              "properties": {
                "request": { "$ref": "#/$defs/httpRequest" },
                "response": { "$ref": "#/$defs/httpResponse" }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["script"],
          "properties": {
            "script": {
              "type": "object",
              "additionalProperties": false,
              "required": ["file"],
              "properties": {
                "file": { "$ref": "#/$defs/relativePath" },
                "modules": {
                  "type": "array",
                  "maxItems": 32,
                  "uniqueItems": true,
                  "items": { "$ref": "#/$defs/relativePath" }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["snapshot"],
          "properties": {
            "snapshot": {
              "type": "object",
              "additionalProperties": false,
              "required": ["entity", "exact", "freshness"],
              "properties": {
                "entity": { "$ref": "#/$defs/stableId" },
                "exact": {
                  "type": "object",
                  "minProperties": 1,
                  "maxProperties": 8,
                  "additionalProperties": { "$ref": "#/$defs/inputReference" }
                },
                "freshness": { "type": "string", "pattern": "^[1-9][0-9]*(?:ms|s|m|h|d)$" }
              }
            }
          }
        }
      ]
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "$ref": "#/$defs/scalarType" },
        "format": { "const": "date" },
        "maxLength": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "minimum": { "type": "integer" },
        "maximum": { "type": "integer" },
        "x-registry-source": {
          "type": "string",
          "pattern": "^/(?:[^/~]|~[01])+(?:/(?:[^/~]|~[01])+)*$"
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "calls": { "type": "integer", "minimum": 1, "maximum": 16 },
        "request_bytes": { "$ref": "#/$defs/byteSize" },
        "source_bytes": { "$ref": "#/$defs/byteSize" },
        "deadline": { "type": "string", "pattern": "^[1-9][0-9]*(?:ms|s)$" }
      }
    }
  }
}
