# Generated by registryctl.
server:
  bind: 0.0.0.0:8080
  openapi_requires_auth: false

auth:
  mode: api_key
  api_keys:
    - id: {{evaluator_id}}
      fingerprint:
        provider: env
        name: REGISTRY_NOTARY_TUTORIAL_EVALUATOR_HASH
        commitment: {{evaluator_commitment}}
      scopes:
        - civil_registry:evidence_verification
      authorization_details:
        type: registry-notary/evidence-authorization/v1
        schema_version: v1
        legal_basis_ref: registryctl:opencrvs-dci:demo-legal-basis
        consent_ref: registryctl:opencrvs-dci:demo-consent
        jurisdiction: ZZ
        assurance_level: substantial

audit:
  sink: stdout
  hash_secret_env: REGISTRY_NOTARY_AUDIT_HASH_SECRET

replay:
  storage: redis
  redis:
    url_env: REGISTRY_NOTARY_REPLAY_REDIS_URL
    key_prefix: registryctl-opencrvs-dci-notary

evidence:
  enabled: true
  service_id: registryctl.opencrvs-dci.notary
  api_base_url: http://127.0.0.1:4255
  inline_batch_limit: 10
  source_connections:
    {{source_connection}}:
      base_url: {{source_url}}
      allow_insecure_localhost: true
      allow_insecure_private_network: true
      source_auth:
        type: oauth2_client_credentials
        token_url: {{source_url}}/oauth2/client/token
        client_id_env: DCI_CLIENT_ID
        client_secret_env: DCI_CLIENT_SECRET
        request_format: json
      max_in_flight: 4
      retry_on_5xx: {{source_retry_on_5xx}}
      bulk_mode: {{source_bulk_mode}}
      dci:
        search_path: /registry/sync/search
        sender_id: registry-notary
        query_type: idtype-value
        registry_type: ns:org:RegistryType:Civil
        registry_event_type: birth
        records_path: /message/search_response/0/data/reg_records
        field_paths:
          observed_at: "$response:/message/search_response/0/timestamp"
  signing_keys:
    {{issuer_key_id}}:
      provider: local_jwk_env
      private_jwk_env: REGISTRY_NOTARY_ISSUER_JWK
      alg: EdDSA
      kid: {{issuer_kid}}
      status: active
  claims:
    - id: {{source_claim}}
      title: {{source_claim_title}}
      version: 2026-06
      subject_type: person
      value:
        type: boolean
      inputs:
        - name: target.identifiers.UIN
          type: string
      source_bindings:
        {{source_binding}}:
          connector: {{source_connector}}
          connection: {{source_connection}}
          required_scope: civil_registry:evidence_verification
          dataset: {{source_dataset}}
          entity: {{source_entity}}
          lookup:
            input: target.identifiers.UIN
            field: {{source_lookup_field}}
            op: eq
            cardinality: one
          fields: {}
          matching:
            policy_id: registryctl.opencrvs-dci.birth-record.lookup.v1
            method: configured_lookup
            allowed_purposes:
              - https://example.local/purpose/tutorial
            context_constraints:
              legal_basis:
                required: true
              consent:
                required: true
              jurisdiction:
                permitted:
                  - ZZ
              assurance:
                allowed:
                  - substantial
              source_freshness:
                max_age_seconds: 86400
            source_observed_at_field: observed_at
            sufficient_target_inputs:
              - - target.identifiers.UIN
            allowed_target_inputs:
              - target.identifiers.UIN
            collapse_matching_errors: true
            confidence: high
      rule:
        type: exists
        source: {{source_binding}}
      disclosure:
        default: predicate
        allowed:
          - predicate
          - redacted
      formats:
        - application/vnd.registry-notary.claim-result+json
