# Generated by registryctl.
server:
  bind: 0.0.0.0:8080
  openapi_requires_auth: false

auth:
  mode: api_key
  api_keys:
    - id: {{evaluator_id}}
      fingerprint:
        provider: env
        name: REGISTRY_NOTARY_TUTORIAL_EVALUATOR_HASH
        commitment: {{evaluator_commitment}}
      scopes:
        - source:evidence_verification

audit:
  sink: stdout
  hash_secret_env: REGISTRY_NOTARY_AUDIT_HASH_SECRET

replay:
  storage: redis
  redis:
    url_env: REGISTRY_NOTARY_REPLAY_REDIS_URL
    key_prefix: registryctl-notary

evidence:
  enabled: true
  service_id: registryctl.standalone.notary
  api_base_url: http://127.0.0.1:4255
  inline_batch_limit: 10
  source_connections:
    {{source_connection}}:
      base_url: {{source_url}}
      allow_insecure_localhost: true
      allow_insecure_private_network: true
      token_env: {{source_token_env}}
      max_in_flight: 4
      retry_on_5xx: {{source_retry_on_5xx}}
      bulk_mode: {{source_bulk_mode}}
  signing_keys:
    {{issuer_key_id}}:
      provider: local_jwk_env
      private_jwk_env: REGISTRY_NOTARY_ISSUER_JWK
      alg: EdDSA
      kid: {{issuer_kid}}
      status: active
  claims:
    - id: {{source_claim}}
      title: {{source_claim_title}}
      version: 2026-06
      subject_type: {{source_entity}}
      value:
        type: boolean
      inputs:
        - name: target.id
          type: string
      source_bindings:
        {{source_binding}}:
          connector: {{source_connector}}
          connection: {{source_connection}}
          required_scope: source:evidence_verification
          dataset: {{source_dataset}}
          entity: {{source_entity}}
          lookup:
            input: target.id
            field: {{source_lookup_field}}
            op: eq
            cardinality: one
          fields: {}
      rule:
        type: exists
        source: {{source_binding}}
      disclosure:
        default: predicate
        allowed:
          - predicate
          - redacted
      formats:
        - application/vnd.registry-notary.claim-result+json
