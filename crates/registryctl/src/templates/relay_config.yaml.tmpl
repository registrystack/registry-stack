# Generated by registryctl.
server:
  bind: 0.0.0.0:8080
  openapi_requires_auth: false

metadata:
  source:
    path: /etc/registry-relay/metadata.yaml

catalog:
  title: Benefits Casework Gateway (registryctl sample)
  base_url: http://127.0.0.1:4242
  publisher: Registryctl Local Sample

auth:
  mode: api_key
  api_keys:
    - id: {{metadata_id}}
      fingerprint:
        provider: env
        name: METADATA_READER_HASH
      scopes:
        - benefits_casework:metadata

    - id: {{row_id}}
      fingerprint:
        provider: env
        name: ROW_READER_HASH
      scopes:
        - benefits_casework:metadata
        - benefits_casework:rows

    - id: {{aggregate_id}}
      fingerprint:
        provider: env
        name: AGGREGATE_READER_HASH
      scopes:
        - benefits_casework:metadata
        - benefits_casework:aggregate

audit:
  sink: stdout
  format: jsonl
  hash_secret_env: REGISTRY_RELAY_AUDIT_HASH_SECRET

datasets:
  - id: benefits_casework
    title: Benefits Casework
    description: Synthetic benefits casework registry for local registryctl evaluation.
    owner: Registryctl Local Sample
    sensitivity: personal
    access_rights: restricted
    update_frequency: monthly
    defaults:
      refresh:
        mode: manual

    tables:
      - id: households_table
        source:
          type: file
          path: /var/lib/registry-relay/data/benefits_casework.xlsx
          format:
            xlsx:
              sheet: Households
        primary_key: household_id
        schema:
          strict: true
          fields:
            - name: household_id
              type: string
              nullable: false
            - name: district
              type: string
              nullable: false
            - name: poverty_band
              type: string
              nullable: false
            - name: address_line
              type: string
              nullable: true
              sensitive: true

      - id: persons_table
        source:
          type: file
          path: /var/lib/registry-relay/data/benefits_casework.xlsx
          format:
            xlsx:
              sheet: Persons
        primary_key: person_id
        schema:
          strict: true
          fields:
            - name: person_id
              type: string
              nullable: false
            - name: household_id
              type: string
              nullable: false
            - name: age_band
              type: string
              nullable: false
            - name: eligibility_status
              type: string
              nullable: false
            - name: full_name
              type: string
              nullable: true
              sensitive: true
            - name: national_id
              type: string
              nullable: true
              sensitive: true

    entities:
      - name: household
        title: Household
        description: A synthetic benefits household
        table: households_table
        fields:
          - name: id
            from: household_id
          - name: district
            from: district
          - name: poverty_band
            from: poverty_band
        relationships:
          - name: members
            kind: has_many
            target: person
            foreign_key: household_id
        access:
          metadata_scope: benefits_casework:metadata
          aggregate_scope: benefits_casework:aggregate
          read_scope: benefits_casework:rows
        api:
          default_limit: 100
          max_limit: 1000
          allowed_filters:
            - field: id
              ops: [eq, in]
            - field: district
              ops: [eq, in]
            - field: poverty_band
              ops: [eq, in]
          allowed_expansions: [members]
        aggregates:
          - id: by_district
            description: Count of households by district
            group_by:
              - district
            measures:
              - name: household_count
                function: count
                column: id
            disclosure_control:
              min_group_size: 1
              suppression: omit

      - name: person
        title: Person
        description: A synthetic person in a benefits household
        table: persons_table
        fields:
          - name: id
            from: person_id
          - name: household_id
            from: household_id
          - name: age_band
            from: age_band
          - name: eligibility_status
            from: eligibility_status
        relationships:
          - name: household
            kind: belongs_to
            target: household
            foreign_key: household_id
        access:
          metadata_scope: benefits_casework:metadata
          aggregate_scope: benefits_casework:aggregate
          read_scope: benefits_casework:rows
        api:
          default_limit: 100
          max_limit: 1000
          require_purpose_header: true
          required_filters:
            - id
            - household_id
            - eligibility_status
          required_filter_bindings:
            - field: id
              source: principal_id
          allowed_filters:
            - field: id
              ops: [eq, in]
            - field: household_id
              ops: [eq, in]
            - field: eligibility_status
              ops: [eq, in]
          allowed_expansions: [household]
