# Generated by registryctl.
# TEMPORARY UNRELEASED CUTOVER SCAFFOLD: this file uses transitional_direct.
# It blocks the replacement beta and 1.0 release. Do not use it to start a new
# integration; replace it with a reviewed, hash-pinned Relay profile.
# This file is the Notary contract for the local sample: evaluator API-key
# auth, the Relay evidence source connection, and the starter claim with its
# purpose-gated source binding. Edit claims and bindings as your evidence
# needs change, then run `registryctl doctor` to validate.
deployment:
  profile: local

server:
  bind: 0.0.0.0:8080
  openapi_requires_auth: false

auth:
  mode: api_key
  api_keys:
    - id: {{evaluator_id}}
      fingerprint:
        provider: env
        name: REGISTRY_NOTARY_TUTORIAL_EVALUATOR_HASH
      scopes:
        - benefits_casework:evidence_verification

audit:
  sink: stdout
  hash_secret_env: REGISTRY_NOTARY_AUDIT_HASH_SECRET

replay:
  storage: redis
  redis:
    url_env: REGISTRY_NOTARY_REPLAY_REDIS_URL
    key_prefix: registryctl-notary

evidence:
  enabled: true
  service_id: registryctl.benefits.notary
  api_base_url: http://127.0.0.1:4255
  inline_batch_limit: 10
  source_connections:
    relay:
      base_url: http://registry-relay:8080
      allow_insecure_private_network: true
      token_env: EVIDENCE_SOURCE_REGISTRY_RELAY_TOKEN
      max_in_flight: 4
      retry_on_5xx: true
      bulk_mode: none
  signing_keys:
    {{issuer_key_id}}:
      provider: local_jwk_env
      private_jwk_env: REGISTRY_NOTARY_ISSUER_JWK
      alg: EdDSA
      kid: {{issuer_kid}}
      status: active
  claims:
    - id: benefits-person-exists
      title: Benefits person exists
      version: 2026-06
      subject_type: person
      evidence_mode:
        type: transitional_direct
      value:
        type: boolean
      inputs:
        - name: target.id
          type: string
      source_bindings:
        person:
          connector: registry_data_api
          connection: relay
          required_scope: benefits_casework:evidence_verification
          dataset: benefits_casework
          entity: person
          lookup:
            input: target.id
            field: id
            op: eq
            cardinality: one
          fields: {}
          matching:
            # Purposes this binding accepts. Requests carrying any other
            # purpose are denied with pdp.purpose_not_permitted before any
            # evidence is looked up; an empty list denies everything.
            # Replace or extend this list with your own purpose URIs.
            allowed_purposes:
              - https://example.local/purpose/tutorial
      rule:
        type: exists
        source: person
      disclosure:
        default: predicate
        allowed:
          - predicate
          - redacted
      formats:
        - application/vnd.registry-notary.claim-result+json
