  "sh:shapesGraph": [
    {
      "@id": "https://civil-registration.example.gov/metadata/schema/vital-events/person/schema.json",
      "@type": "sh:NodeShape",
      "dcterms:identifier": "vital-events:person",
      "dcterms:isPartOf": "#dataset-vital-events",
      "registry_manifest:primaryKey": "person_id",
      "sh:name": "person",
      "sh:nodeKind": "sh:IRI",
      "sh:property": [
        {
          "@type": "sh:PropertyShape",
          "sh:datatype": "xsd:date",
          "sh:maxCount": 1,
          "sh:minCount": 0,
          "sh:name": "birth_date",
          "sh:nodeKind": "sh:Literal",
          "sh:path": "https://person-schema.example.gov/vocab/Person.birthDate"
        },
        {
          "@type": "sh:PropertyShape",
          "sh:datatype": "xsd:string",
          "sh:maxCount": 1,
          "sh:maxLength": 64,
          "sh:minCount": 1,
          "sh:minLength": 1,
          "sh:name": "person_id",
          "sh:nodeKind": "sh:Literal",
          "sh:path": "https://person-schema.example.gov/vocab/Person.identifier",
          "sh:pattern": "^[A-Za-z0-9-]+$"
        },
        {
          "@type": "sh:PropertyShape",
          "sh:datatype": "xsd:string",
          "sh:maxCount": 1,
          "sh:minCount": 0,
          "sh:name": "sex",
          "sh:nodeKind": "sh:Literal",
          "sh:path": "https://person-schema.example.gov/vocab/Person.sex",
          "skos:inScheme": "https://civil-registration.example.gov/codelists/sex"
        }
      ],
      "sh:targetClass": "https://civil-registration.example.gov/metadata/datasets/vital-events/entities/person"
    },
    {
      "@id": "https://civil-registration.example.gov/metadata/schema/vital-events/vital_event/schema.json",
