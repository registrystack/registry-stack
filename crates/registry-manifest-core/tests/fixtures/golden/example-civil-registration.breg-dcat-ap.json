      "dcterms:identifier": "vital-events:vital_event",
      "dcterms:isPartOf": "#dataset-vital-events",
      "registry_manifest:primaryKey": "event_id",
      "sh:name": "vital_event",
      "sh:nodeKind": "sh:IRI",
      "sh:property": [
        {
          "@type": "sh:PropertyShape",
          "sh:datatype": "xsd:string",
          "sh:maxCount": 1,
          "sh:minCount": 1,
          "sh:name": "event_id",
          "sh:nodeKind": "sh:Literal",
          "sh:path": "https://civil-registration.example.gov/vocab/VitalEvent.identifier"
        },
        {
          "@type": "sh:PropertyShape",
          "sh:datatype": "xsd:string",
          "sh:in": [
            "birth",
            "death"
          ],
          "sh:maxCount": 1,
          "sh:minCount": 1,
          "sh:name": "event_type",
          "sh:nodeKind": "sh:Literal",
          "sh:path": "https://civil-registration.example.gov/vocab/VitalEvent.type",
          "skos:inScheme": "https://civil-registration.example.gov/codelists/vital-event-type"
        },
        {
          "@type": "sh:PropertyShape",
          "sh:datatype": "xsd:date",
          "sh:maxCount": 1,
          "sh:minCount": 0,
          "sh:name": "registration_date",
          "sh:nodeKind": "sh:Literal",
          "sh:path": "https://civil-registration.example.gov/vocab/VitalEvent.registrationDate"
        }
      ],
      "sh:targetClass": "https://civil-registration.example.gov/metadata/datasets/vital-events/entities/vital_event"
