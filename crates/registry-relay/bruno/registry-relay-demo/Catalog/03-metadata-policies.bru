meta {
  name: Metadata policies
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/metadata/policies
  body: none
  auth: bearer
}

auth:bearer {
  token: {{metadataKey}}
}

docs {
  Reads the scoped ODRL policy collection. Uses catalog_viewer persona (metadataKey).
  Expected: 200 with JSON-LD offers for datasets visible to the caller's metadata scopes.
}
