{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry-relay.local/demo/schemas/spdci/sr-social-group.schema.json",
  "title": "Demo SP DCI Social Registry Group",
  "$comment": "Shaped from third_party/spdci-api-standards/src/registry/social/RegistryRecord.yaml and src/extensions/social/Group.yaml.",
  "type": "object",
  "required": ["@id", "@type", "group_identifier", "group_type", "group_head_info"],
  "properties": {
    "@id": { "type": "string" },
    "@type": { "type": "string" },
    "group_identifier": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["identifier_type", "identifier_value"],
        "properties": {
          "identifier_type": { "type": "string" },
          "identifier_value": { "type": "string" }
        }
      }
    },
    "group_type": { "type": "string" },
    "place": { "type": "object" },
    "poverty_score": { "type": "number" },
    "poverty_score_type": { "type": "string" },
    "group_size": { "type": "integer" },
    "group_head_info": { "type": "object" },
    "registration_date": { "type": "string" },
    "last_updated": { "type": "string" }
  }
}
