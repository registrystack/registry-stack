# Pure-Rust source-adapter sidecar image. The OpenFn execution engine is retired
# in registry-notary, so this image no longer builds the Node worker pool or
# installs npm adaptors. The runtime base stays node:22-bookworm-slim because the
# civil demo's mock registry (mock-registry-server.mjs, vendored into this repo)
# is a small Node http server; the Rust sidecar binary itself needs no Node. curl
# is installed so the compose /ready healthchecks work. The image name/tag
# (registry-notary-openfn-sidecar:demo) and the invoked binary name are kept
# stable for compose and cross-repo compatibility.

FROM rust:1-bookworm@sha256:5e2214abe154fe26e39f64488952e5c991eeed1d6d6da7cc8381ae83927f0cfc AS builder

WORKDIR /workspace/registry-stack
COPY --from=registry_platform_src Cargo.toml Cargo.lock LICENSE ./
COPY --from=registry_platform_src crates ./crates
COPY --from=registry_platform_src products/notary/xtask ./products/notary/xtask

# The crate's binary was renamed to registry-notary-source-adapter-sidecar when
# the OpenFn engine was retired; install it under the historical
# registry-notary-openfn-sidecar name so compose commands stay unchanged.
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
    --mount=type=cache,target=/workspace/target \
    CARGO_TARGET_DIR=/workspace/target cargo build --release --locked -p registry-notary-source-adapter-sidecar --bin registry-notary-source-adapter-sidecar \
    && cp /workspace/target/release/registry-notary-source-adapter-sidecar /usr/local/bin/registry-notary-openfn-sidecar

FROM node:22-bookworm-slim@sha256:813a7480f28fdadac1f7f5c824bcdad435b5bc1322a5968bbbdef8d058f9dff4 AS runtime

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/openfn
COPY --from=builder /usr/local/bin/registry-notary-openfn-sidecar /usr/local/bin/registry-notary-openfn-sidecar
# Mock civil registry server for the demo (vendored here; formerly shipped by
# registry-notary). Pure node:http with no npm dependencies, so no npm install.
COPY config/openfn/mock-registry-server.mjs ./mock-registry-server.mjs

USER node
EXPOSE 8080

ENTRYPOINT ["registry-notary-openfn-sidecar"]
