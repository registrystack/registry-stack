{
  "schema_version": "registry-lab/evidence-gateway-binding/v1",
  "binding": {
    "id": "birth-certificate-evidence/v1",
    "version": "v1",
    "profile": "birth-certificate-evidence",
    "type": "governed-evidence",
    "description": "Birth Evidence pack for minimized JSON responses.",
    "source_configs": [
      "config/relay/civil-registry-relay.metadata.yaml",
      "config/notary/civil-notary.yaml"
    ],
    "synthetic_data": "config/evidence-gateway/synthetic/birth-certificate-evidence.v1.json",
    "golden_fixtures": "config/evidence-gateway/golden/birth-certificate-evidence.v1.json"
  },
  "evidence_pack": {
    "pack_id": "birth-certificate-evidence/v1",
    "pack_version": "v1",
    "pack_title": "Birth Evidence",
    "source_basis": {
      "family": "oots-common-data-model",
      "evidence_type": "Birth Evidence",
      "adaptation": "jurisdiction-neutral-publicschema"
    },
    "matching_modes": [
      {
        "mode": "identifier",
        "status": "implemented",
        "input": "target.identifiers.registration_number",
        "identifier_scheme": "registration_number"
      },
      {
        "mode": "demographic",
        "status": "implemented",
        "input": "target.attributes.given_name + target.attributes.surname + target.attributes.birth_date",
        "identifier_scheme": "given_name_surname_birth_date",
        "claim_id": "birth.certificate_summary_by_demographics"
      }
    ],
    "policy_id": "lab.birth-certificate-evidence.governed-evidence.v1",
    "policy_hash": "sha256:0683b8cc550406aa570d404aaa617a15fe74c47799a2129306ed17e8829eb679",
    "output_profile": "oots_object_json",
    "deferred_outputs": [
      "application/dc+sd-jwt",
      "application/ld+json; profile=\"cccev\""
    ],
    "odrl_enforcement": {
      "profile": "registry-evidence-gateway-pdp/v1",
      "constraint_terms": [
        "odrl:purpose",
        "odrl:spatial"
      ],
      "unsupported_terms_fail_closed": true,
      "compile_target": "native-pdp"
    },
    "pdp_gates": [
      {
        "term": "registry:pdp:assurance",
        "operator": "odrl:gteq",
        "rightOperand": "substantial"
      },
      {
        "term": "registry:pdp:source_age",
        "operator": "odrl:lteq",
        "rightOperand": 86400
      },
      {
        "term": "registry:pdp:legal_basis",
        "operator": "odrl:isA",
        "rightOperand": "demo:birth-certificate-evidence"
      },
      {
        "term": "registry:pdp:consent",
        "operator": "odrl:isA",
        "rightOperand": "demo:birth-certificate-consent"
      },
      {
        "term": "registry:pdp:credential_format",
        "operator": "odrl:isA",
        "rightOperand": "minimized_json"
      }
    ]
  },
  "odrl_policy": {
    "@context": [
      "https://www.w3.org/ns/odrl.jsonld"
    ],
    "@type": "Set",
    "uid": "urn:registry-lab:policy:birth-certificate-evidence:wave-a:v1",
    "profile": "registry-evidence-gateway-pdp/v1",
    "permission": [
      {
        "uid": "urn:registry-lab:rule:birth-certificate-evidence:purpose:wave-a",
        "action": "odrl:use",
        "target": "urn:registry-lab:evidence:birth-certificate-evidence:v1",
        "constraint": [
          {
            "leftOperand": "odrl:purpose",
            "operator": "odrl:isA",
            "rightOperand": "https://demo.example.gov/purpose/civil-certificate-evidence"
          },
          {
            "leftOperand": "odrl:spatial",
            "operator": "odrl:isA",
            "rightOperand": "ZZ"
          }
        ]
      }
    ]
  }
}
