{
  "title": "Registry Lab",
  "subtitle": "A live sandbox where a public service gets a yes/no proof instead of a full registry record.",
  "environment": {
    "name": "Hosted lab",
    "domain": "lab.registrystack.org",
    "notice": "Synthetic demo data, safe to test."
  },
  "services": [
    {
      "id": "self-attested-notary",
      "label": "Self-attested Notary",
      "url": "https://self-attested-notary.lab.registrystack.org",
      "purpose": "Evaluates the applicant declaration without consulting a registry.",
      "status_path": "/.well-known/evidence-service",
      "status_credential_id": "self-attested-evidence"
    },
    {
      "id": "civil-relay",
      "label": "Civil Relay",
      "url": "https://civil-relay.lab.registrystack.org",
      "purpose": "Serves demo civil registration records through a protected, read-only API.",
      "status_path": "/healthz",
      "status_credential_id": "civil-metadata"
    },
    {
      "id": "social-relay",
      "label": "Social Protection Relay",
      "url": "https://social-relay.lab.registrystack.org",
      "purpose": "Serves demo social protection data (households, people, enrollments) through a protected, read-only API.",
      "status_path": "/healthz",
      "status_credential_id": "social-metadata"
    },
    {
      "id": "health-relay",
      "label": "Health Relay",
      "url": "https://health-relay.lab.registrystack.org",
      "purpose": "Serves demo applicant service-availability projections derived from facility licensing data through a protected, read-only API.",
      "status_path": "/healthz",
      "status_credential_id": "health-metadata"
    },
    {
      "id": "agri-relay",
      "label": "Agriculture Relay",
      "url": "https://agri-relay.lab.registrystack.org",
      "purpose": "Serves demo NAgDI agriculture records through a protected, read-only API.",
      "status_path": "/healthz",
      "status_credential_id": "agri-metadata"
    },
    {
      "id": "metadata",
      "label": "Static Metadata",
      "url": "https://metadata.lab.registrystack.org",
      "purpose": "Publishes the catalog that describes what the other services offer.",
      "status_path": "/"
    },
    {
      "id": "esignet",
      "label": "eSignet",
      "url": "https://esignet.lab.registrystack.org",
      "purpose": "Signs the demo citizen in for the wallet test.",
      "status_path": "/v1/esignet/oidc/.well-known/openid-configuration"
    },
    {
      "id": "esignet-ui",
      "label": "eSignet UI",
      "url": "https://esignet-ui.lab.registrystack.org",
      "purpose": "The login screen the citizen sees during the wallet test.",
      "status_path": "/.well-known/openid-configuration"
    },
    {
      "id": "zitadel",
      "label": "Zitadel",
      "url": "https://zitadel.lab.registrystack.org",
      "purpose": "An identity provider used to sign in to some of the Relay demos.",
      "status_path": "/.well-known/openid-configuration"
    }
  ],
  "credentials": [
    {
      "id": "self-attested-evidence",
      "label": "Self-attested Notary API key",
      "env": "SELF_ATTESTED_EVIDENCE_CLIENT_TOKEN",
      "service_url": "https://self-attested-notary.lab.registrystack.org",
      "auth_scheme": "api_key",
      "default_purpose": "application-processing",
      "default_subject": "demo-applicant",
      "default_identifier_scheme": "applicant_id",
      "scopes": ["evidence:declaration:read"],
      "example": {"method": "POST", "path": "/v1/evaluations"}
    },
    {
      "id": "civil-metadata",
      "label": "Civil Relay metadata",
      "env": "CIVIL_METADATA_CLIENT_RAW",
      "service_url": "https://civil-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["civil_registry:metadata"],
      "example": {"method": "GET", "path": "/v1/datasets"}
    },
    {
      "id": "civil-evidence-only",
      "label": "Civil Relay evidence verification",
      "env": "CIVIL_EVIDENCE_ONLY_RAW",
      "service_url": "https://civil-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["civil_registry:metadata", "civil_registry:evidence_verification"],
      "example": {"method": "GET", "path": "/metadata/evidence-offerings", "positive_subject": "NID-1001"}
    },
    {
      "id": "civil-row-reader",
      "label": "Civil Relay row reader",
      "env": "CIVIL_ROW_READER_RAW",
      "service_url": "https://civil-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["civil_registry:metadata", "civil_registry:rows"],
      "required_headers": {"Data-Purpose": "https://demo.example.gov/purpose/decentralized-evidence-demo"},
      "example": {"method": "GET", "path": "/v1/datasets/civil_registry/entities/civil_person/records?limit=1"}
    },
    {
      "id": "social-metadata",
      "label": "Social Protection Relay metadata",
      "env": "SOCIAL_METADATA_CLIENT_RAW",
      "service_url": "https://social-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["social_protection_registry:metadata"],
      "example": {"method": "GET", "path": "/v1/datasets"}
    },
    {
      "id": "social-evidence-only",
      "label": "Social Protection Relay evidence verification",
      "env": "SOCIAL_EVIDENCE_ONLY_RAW",
      "service_url": "https://social-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["social_protection_registry:metadata", "social_protection_registry:evidence_verification"],
      "example": {"method": "GET", "path": "/metadata/evidence-offerings", "positive_subject": "NID-1001"}
    },
    {
      "id": "social-row-reader",
      "label": "Social Protection Relay row reader",
      "env": "SOCIAL_ROW_READER_RAW",
      "service_url": "https://social-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["social_protection_registry:metadata", "social_protection_registry:rows"],
      "required_headers": {"Data-Purpose": "https://demo.example.gov/purpose/decentralized-evidence-demo"},
      "example": {"method": "GET", "path": "/v1/datasets/social_protection_registry/entities/household/records?limit=1"}
    },
    {
      "id": "social-aggregate-reader",
      "label": "Social Protection Relay aggregate reader",
      "env": "SOCIAL_AGGREGATE_READER_RAW",
      "service_url": "https://social-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["social_protection_registry:metadata", "social_protection_registry:aggregate"],
      "required_headers": {"Data-Purpose": "https://demo.example.gov/purpose/decentralized-evidence-demo"},
      "example": {"method": "GET", "path": "/v1/datasets/social_protection_registry/aggregates/households_by_eligibility_band"}
    },
    {
      "id": "health-metadata",
      "label": "Health Relay metadata",
      "env": "HEALTH_METADATA_CLIENT_RAW",
      "service_url": "https://health-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["health_registry:metadata"],
      "example": {"method": "GET", "path": "/v1/datasets"}
    },
    {
      "id": "health-evidence-only",
      "label": "Health Relay evidence verification",
      "env": "HEALTH_EVIDENCE_ONLY_RAW",
      "service_url": "https://health-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["health_registry:metadata", "health_registry:evidence_verification"],
      "example": {"method": "GET", "path": "/metadata/evidence-offerings", "positive_subject": "NID-1001"}
    },
    {
      "id": "health-row-reader",
      "label": "Health Relay row reader",
      "env": "HEALTH_ROW_READER_RAW",
      "service_url": "https://health-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["health_registry:metadata", "health_registry:rows"],
      "required_headers": {"Data-Purpose": "https://demo.example.gov/purpose/decentralized-evidence-demo"},
      "example": {"method": "GET", "path": "/v1/datasets/health_registry/entities/health_facility/records?limit=1"}
    },
    {
      "id": "agri-metadata",
      "label": "Agriculture Relay metadata",
      "env": "AGRI_METADATA_CLIENT_RAW",
      "service_url": "https://agri-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["agri_registry:metadata"],
      "example": {"method": "GET", "path": "/v1/datasets"}
    },
    {
      "id": "agri-evidence-only",
      "label": "Agriculture Relay evidence verification",
      "env": "AGRI_EVIDENCE_ONLY_RAW",
      "service_url": "https://agri-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["agri_registry:metadata", "agri_registry:evidence_verification"],
      "example": {"method": "GET", "path": "/metadata/evidence-offerings", "positive_subject": "FARMER-1001"}
    },
    {
      "id": "agri-row-reader",
      "label": "Agriculture Relay row reader",
      "env": "AGRI_ROW_READER_RAW",
      "service_url": "https://agri-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["agri_registry:metadata", "agri_registry:rows"],
      "required_headers": {"Data-Purpose": "https://demo.example.gov/purpose/nagdi/climate-smart-input-support"},
      "example": {"method": "GET", "path": "/v1/datasets/agri_registry/entities/farmer/records?limit=1"}
    },
    {
      "id": "agri-aggregate-reader",
      "label": "Agriculture Relay aggregate reader",
      "env": "AGRI_AGGREGATE_READER_RAW",
      "service_url": "https://agri-relay.lab.registrystack.org",
      "auth_scheme": "api_key",
      "scopes": ["agri_registry:metadata", "agri_registry:aggregate"],
      "required_headers": {"Data-Purpose": "https://demo.example.gov/purpose/nagdi/climate-smart-input-support"},
      "example": {"method": "GET", "path": "/v1/datasets/agri_registry/aggregates/farmers_by_district_and_status"}
    }
  ]
}
