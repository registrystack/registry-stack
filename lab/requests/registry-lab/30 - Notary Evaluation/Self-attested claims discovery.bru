meta {
  name: Self-attested claims discovery
  type: http
  seq: 1
}

get {
  url: {{self_attested_notary_url}}/v1/claims
  body: none
  auth: none
}

headers {
  x-api-key: {{SELF_ATTESTED_EVIDENCE_CLIENT_TOKEN}}
  Accept: application/json
}

script:post-response {
  const body = res.getBody();

  test("returns claims", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("advertises the applicant declaration", function () {
    expect(body.data.some((item) => item.id === "applicant-declaration")).to.be.true;
  });
}
