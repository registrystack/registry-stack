meta {
  name: Self-attested purpose denied
  type: http
  seq: 3
}

post {
  url: {{self_attested_notary_url}}/v1/evaluations
  body: json
  auth: none
}

headers {
  x-api-key: {{SELF_ATTESTED_EVIDENCE_CLIENT_TOKEN}}
  Content-Type: application/json
  Data-Purpose: unrelated-purpose
}

body:json {
  {
    "target": {
      "type": "Person",
      "identifiers": [
        {
          "scheme": "application_reference",
          "value": "SYNTHETIC-APPLICATION-001"
        }
      ]
    },
    "claims": ["applicant-declaration"],
    "disclosure": "predicate",
    "format": "application/vnd.registry-notary.claim-result+json"
  }
}

script:post-response {
  const body = res.getBody();

  test("status is 403", function () {
    expect(res.getStatus()).to.equal(403);
  });

  test("service policy denies the unrelated purpose", function () {
    expect(body).to.have.property("code");
    expect(body.code).to.match(/purpose|policy/);
  });
}
