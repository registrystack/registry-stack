meta {
  name: Self-attested declaration positive
  type: http
  seq: 2
}

post {
  url: {{self_attested_notary_url}}/v1/evaluations
  body: json
  auth: none
}

headers {
  x-api-key: {{SELF_ATTESTED_EVIDENCE_CLIENT_TOKEN}}
  Content-Type: application/json
  Data-Purpose: application-processing
}

body:json {
  {
    "target": {
      "type": "Person",
      "identifiers": [
        {
          "scheme": "application_reference",
          "value": "SYNTHETIC-APPLICATION-001"
        }
      ]
    },
    "claims": ["applicant-declaration"],
    "disclosure": "predicate",
    "format": "application/vnd.registry-notary.claim-result+json"
  }
}

script:post-response {
  const body = res.getBody();
  const results = body.results || body.claim_results || [];
  const declaration = results.find((result) => (result.claim || result.claim_id) === "applicant-declaration");

  test("status is 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("source-free declaration is satisfied", function () {
    expect(declaration).to.exist;
    expect(declaration.satisfied === true || declaration.value === true).to.equal(true);
  });
}
